---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import LoadingScreen from "../components/ui/LoadingScreen";

interface Props {
  title?: string;
}

const { title = "UBC Game Development" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <title>{title}</title>
    <SpeedInsights />
    <Analytics />
  </head>
  <body
    class="overflow-x-hidden bg-[var(--bg-deep)] text-[var(--text-main)] selection:bg-[var(--accent)] selection:text-white">
    <LoadingScreen client:only="react" />

    <!-- Background Base -->
    <div class="fixed inset-0 z-0 bg-[var(--bg-deep)]">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--bg-panel)_0%,_var(--bg-deep)_100%)] opacity-40">
      </div>
    </div>

    <!-- HUD Overlay Top -->
    <div class="fixed top-0 left-0 z-50 h-1 w-full bg-[var(--brand)] shadow-[0_0_10px_var(--brand)]"></div>

    <div class="relative z-10 flex min-h-screen flex-col">
      <Navbar />
      <main class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
