---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <link
      rel="icon"
      type="image/png"
      href="/favicon.png"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <title>UBC Game Development</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <Navbar />
    <slot />
    <Footer
      socials={[
        {
          label: "Discord",
          href: "https://discord.gg/your-invite",
          external: true,
        },
        {
          label: "Instagram",
          href: "https://instagram.com/ubcgamedev",
          external: true,
        },
        {
          label: "GitHub",
          href: "https://github.com/ubcgamedev",
          external: true,
        },
        {
          label: "Twitch",
          href: "https://twitch.tv/ubcgamedev",
          external: true,
        },
        { label: "Website", href: "/", external: false },
      ]}
    />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
