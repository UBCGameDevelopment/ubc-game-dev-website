---
import { Image } from "astro:assets";
import type { Event } from "../../types";
import BaseCard from "../common/Card/BaseCard.astro";
import Badge from "../common/Badge/Badge.astro";
import CalendarIcon from "../common/Icons/CalendarIcon.astro";
import LocationIcon from "../common/Icons/LocationIcon.astro";
import GradientHeading from "../common/Typography/GradientHeading.astro";

export interface Props extends Event {}

const { title, date, description, location, mapLink, image, isActive } = Astro.props;
---

<BaseCard>
  <div class:list={["p-4 md:p-6", { "pointer-events-none opacity-50": !isActive }]}>
    <!-- Grid Layout: Image Left, Content Right -->
    <div class="grid gap-4 md:grid-cols-2 md:gap-6">
      <!-- Left Section: Event Image -->
      <div class="flex flex-col justify-center">
        <div class="relative overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--surface-2)] shadow-sm">
          <Image
            src={image}
            alt={title}
            class:list={[
              "w-full object-cover transition-transform duration-500",
              { grayscale: !isActive, "group-hover:scale-105": isActive },
            ]}
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right Section: Event Info -->
      <div class="flex flex-col">
        <!-- Event Badge or Passed Badge -->
        <Badge
          label={isActive ? "Event" : "Passed"}
          variant="event"
          class="mb-2"
        />

        <!-- Event Title -->
        <GradientHeading
          as="h3"
          class="mb-2 text-xl md:text-2xl"
        >
          {title}
        </GradientHeading>

        <!-- Event Date -->
        <div class="mb-2 flex items-center gap-2 text-sm text-[var(--text-muted)]">
          <CalendarIcon />
          <span class="font-semibold text-[var(--text)]">{date}</span>
        </div>

        <!-- Event Description -->
        <p
          class="mb-3 text-sm leading-relaxed text-[var(--text-muted)]"
          set:html={description}
        />

        <!-- Event Location -->
        <div class="mt-auto flex items-center gap-2 text-sm text-[var(--text-muted)]">
          <LocationIcon />
          {
            mapLink && isActive ? (
              <a
                class="font-medium text-[var(--text)] hover:underline"
                href={mapLink}
                target="_blank"
              >
                {location}
              </a>
            ) : (
              <span class="font-medium text-[var(--text)]">{location}</span>
            )
          }
        </div>
      </div>
    </div>
  </div>
</BaseCard>
