---
import { Image } from "astro:assets";
import type { Event } from "../../types";
import BaseCard from "../common/Card/BaseCard.astro";
import Badge from "../common/Badge/Badge.astro";
import CalendarIcon from "../common/Icons/CalendarIcon.astro";
import LocationIcon from "../common/Icons/LocationIcon.astro";
import GradientHeading from "../common/Typography/GradientHeading.astro";

export interface Props extends Event {}

const { title, date, description, location, mapLink, image } = Astro.props;
---

<BaseCard>
    <div class="p-4 md:p-6">
        <!-- Grid Layout: Image Left, Content Right -->
        <div class="grid gap-4 md:grid-cols-2 md:gap-6">
            <!-- Left Section: Event Image -->
            <div class="flex flex-col justify-center">
                <div
                    class="relative aspect-video overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-white/[0.05] to-white/[0.02] ring-1 ring-white/10">
                    <Image
                        src={image}
                        alt={title}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                    />
                </div>
            </div>

            <!-- Right Section: Event Info -->
            <div class="flex flex-col">
                <!-- Event Badge -->
                <Badge
                    label="Event"
                    variant="event"
                    class="mb-2"
                />

                <!-- Event Title -->
                <GradientHeading
                    as="h3"
                    class="mb-2 text-xl md:text-2xl">
                    {title}
                </GradientHeading>

                <!-- Event Date -->
                <div class="mb-2 flex items-center gap-2 text-sm">
                    <CalendarIcon />
                    <span class="font-semibold text-gray-200">{date}</span>
                </div>

                <!-- Event Description -->
                <p class="mb-3 text-sm leading-relaxed text-gray-50/80">
                    {description}
                </p>

                <!-- Event Location -->
                <div class="mt-auto flex items-center gap-2 text-sm">
                    <LocationIcon />
                    {
                        mapLink ? (
                            <a
                                class="font-medium text-gray-200 hover:underline"
                                href={mapLink}
                                target="_blank">
                                {location}
                            </a>
                        ) : (
                            <span class="font-medium text-gray-200">{location}</span>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</BaseCard>
