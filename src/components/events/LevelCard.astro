---
import { Image } from "astro:assets";
import type { Event } from "../../types";

export interface Props extends Event {
  chapterNumber: number;
}

const { title, date, description, location, mapLink, image, isActive, chapterNumber } = Astro.props;
---

<div
  class:list={[
    "group relative overflow-hidden rounded-2xl border transition-all duration-300",
    isActive
      ? "border-[var(--brand)]/30 bg-[var(--surface-2)] hover:border-[var(--brand)] hover:shadow-[0_0_30px_rgba(168,85,247,0.15)]"
      : "border-[var(--border)] bg-[var(--surface-2)]/50 opacity-60",
  ]}
>
  <!-- Chapter Number Badge -->
  <div
    class:list={[
      "font-pixel absolute top-4 left-4 z-20 flex h-12 w-12 items-center justify-center rounded-xl border-2 text-lg shadow-lg",
      isActive
        ? "border-[var(--brand)] bg-[var(--brand)] text-white shadow-[var(--brand)]/30"
        : "border-[var(--border)] bg-[var(--surface)] text-[var(--text-muted)]",
    ]}
  >
    {chapterNumber}
  </div>

  <!-- Status Badge -->
  {
    !isActive && (
      <div class="absolute top-4 right-4 z-20 rounded-lg bg-[var(--surface)] px-3 py-1 text-xs font-semibold tracking-wide text-[var(--text-muted)] uppercase">
        Completed
      </div>
    )
  }
  {
    isActive && (
      <div class="absolute top-4 right-4 z-20 flex items-center gap-2 rounded-lg border border-[var(--brand)] bg-[var(--brand)] px-3 py-1.5 text-xs font-bold text-white shadow-[var(--brand)]/30 shadow-lg">
        <span class="h-2 w-2 animate-pulse rounded-full bg-white" />
        Active
      </div>
    )
  }

  <!-- Image Section -->
  <div class="relative aspect-[16/9] overflow-hidden">
    <Image
      src={image}
      alt={title}
      class:list={[
        "h-full w-full object-cover transition-all duration-500",
        isActive ? "group-hover:scale-105" : "grayscale",
      ]}
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--surface-2)] via-transparent to-transparent"></div>
  </div>

  <!-- Content Section -->
  <div class="relative p-6">
    <!-- Title -->
    <h3 class="font-pixel text-xl text-[var(--text)] md:text-2xl">
      {title}
    </h3>

    <!-- Date & Location -->
    <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-[var(--text-muted)]">
      <div class="flex items-center gap-2">
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          >
          </path>
        </svg>
        <span class="font-medium text-[var(--text)]">{date}</span>
      </div>
      {
        location && (
          <div class="flex items-center gap-2">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            {mapLink && isActive ? (
              <a
                href={mapLink}
                target="_blank"
                class="font-medium text-[var(--text)] hover:text-[var(--brand)] hover:underline"
              >
                {location}
              </a>
            ) : (
              <span class="font-medium text-[var(--text)]">{location}</span>
            )}
          </div>
        )
      }
    </div>

    <!-- Description -->
    <p
      class="mt-4 line-clamp-2 text-sm leading-relaxed text-[var(--text-muted)]"
      set:html={description}
    />

    <!-- Action Button -->
    {
      isActive && (
        <div class="mt-6">
          <button
            type="button"
            data-open-modal={chapterNumber - 1}
            class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-[var(--brand)] px-5 py-2.5 font-semibold text-white shadow-[var(--brand)]/20 shadow-lg transition-all hover:-translate-y-0.5 hover:shadow-[var(--brand)]/30 hover:shadow-xl"
          >
            View Details
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"
              />
            </svg>
          </button>
        </div>
      )
    }
  </div>
</div>
