---
/**
 * WhoWeAre – composed of alternating InfoBlocks.
 * Manually control heading colors with `headingClass` to avoid extra logic.
 */
import InfoBlock from "./InfoBlock.astro";
---

<section class="bg-gray-800">
    <!-- WHO WE ARE -->
    <InfoBlock
        title="Who We Are"
        headingClass="text-purple-400"
        imageSrc="src/assets/president_headshot.webp"
        imageAlt="Alt Text"
    >
        <p>
            We bring together artists, programmers, writers, and musicians to
            make games!
            <span class="font-semibold text-gray-100">
                No previous experience required</span
            > — you can join a team and start working on a game with other budding
            developers!
        </p>
        <p class="mt-4">
            We also have a <span class="font-semibold text-green-400"
                >Year End Showcase</span
            > where industry judges check out the games and hand out awards!
        </p>
        <p class="mt-4">
            Want to join? Keep an eye on our Discord for sign-up forms, which go
            live after our Launch Party!
        </p>
    </InfoBlock>

    <!-- OUR MISSION (image on left) -->
    <InfoBlock
        title="Our Mission"
        headingClass="text-green-400"
        imageSrc="src/assets/president_headshot.webp"
        imageAlt="Alt Text"
        reverse
    >
        <p>
            We are a student-run video game development club aiming to give
            students a hands-on approach to making video games and provide the
            tools needed to learn more about the industry.
        </p>
        <p class="mt-4">
            At UBC Game Development, we host workshops, invite industry guest
            speakers, and hold regular meetings to help educate our members. We
            aim to give them the tools and knowledge to succeed in the art of
            video game development.
        </p>
    </InfoBlock>

    <!-- HOW IT WORKS -->
    <InfoBlock
        title="How It Works"
        headingClass="text-purple-400"
        imageSrc="src/assets/president_headshot.webp"
        imageAlt="Alt Text"
    >
        <p>
            We split our members into <span class="font-semibold text-green-400"
                >Project Teams</span
            > and a
            <span class="font-semibold text-green-400">
                Learning Community</span
            >.
        </p>
        <p class="mt-4">
            Project Teams are led by experienced members and balanced with a
            variety of skills to successfully design and develop an original
            game.
        </p>
        <p class="mt-4">
            The Learning Community fosters a safe environment for aspiring
            developers to improve skills, experiment, and make connections. Many
            members later transfer into Project Teams once they feel confident.
        </p>
    </InfoBlock>
</section>
