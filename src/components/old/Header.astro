---
import astroLogo from '../assets/astro.svg';
---

<header class="bg-gray-800 font-semibold text-gray-300">
    <nav class="flex justify-between items-center mx-auto px-25 py-2 max-w-8xl">
        <!-- Left: Logo -->
        <a href="/" class="flex items-center space-x-2">
            <img src={astroLogo.src} alt="Astro Logo" class="m-4 h-4 object-contain" />
        </a>
        
        <!-- Nav Links -->
        <ul class="hidden md:flex space-x-10">
            <li><a href="/" class="hover:text-white text-lg hover:underline">Home</a></li>
            <li><a href="/about" class="hover:text-white text-lg hover:underline">About</a></li>
            <li><a href="/events" class="hover:text-white text-lg hover:underline">Events</a></li>
            <li><a href="/team" class="hover:text-white text-lg hover:underline">Team</a></li>
            <li><a href="/contact" class="hover:bg-gradient-to-r from-gray-700 via-gray-800 to-gray-900 px-4 py-1 border-2 border-gray-700 rounded-full hover:text-white text-lg hover:underline">Contact Us</a></li>
        </ul>

        <!-- Mobile menu button -->
        <button class="md:hidden hover:bg-gray-100 p-2 rounded">
            <!-- Simple hamburger icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </nav>
</header>