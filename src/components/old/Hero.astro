---
/**
 * Hero Component for UBC Game Dev Website
 *
 * Props:
 *  - title: Main heading text
 *  - highlight: Highlighted sub-heading or tagline
 *  - subtitle: Supporting description text
 *  - primaryCtaText / primaryCtaHref: Main call-to-action button
 *  - secondaryCtaText / secondaryCtaHref: Secondary call-to-action button
 *  - logoSrc: Path to the club logo (defaults to placeholder in /public)
 *
 * Notes:
 *  - Logo is wrapped in a styled container to allow easy swapping later.
 *  - All content is responsive (stacks vertically on smaller screens).
 *  - Tailwind is used for styling; modify classes directly as needed.
 */
 const {
  title = "UBC Game Development",
  highlight = "Growing Games From The Ground Up.",
  subtitle = "We aim to give students the boost they need to get started with game development. At UBC Game Dev, we develop games from scratch and present them to industry professionals.",
  primaryCtaText = "Become a Member",
  primaryCtaHref = "/join",
  secondaryCtaText = "Connect With Us",
  secondaryCtaHref = "/partners",
  logoSrc = "src/assets/astro.svg", // Replace with actual club logo later
} = Astro.props;
---

<!-- ================= HERO SECTION ================ -->
<section class="relative overflow-hidden bg-gray-900">
  <div class="mx-auto px-6 py-20 sm:py-24 lg:py-28 max-w-7xl">
    <div class="gap-10 grid items-center lg:grid-cols-2">
      
      <!-- LEFT SIDE: Text content -->
      <div class="text-left">
        <h1 class="font-extrabold tracking-tight text-4xl sm:text-5xl lg:text-6xl">
          <span class="block text-white lg:text-8xl">{title}</span>
          <span class="block bg-gradient-to-r from-purple-400 to-green-500 bg-clip-text text-transparent">
            {highlight}
          </span>
        </h1>

        <!-- Supporting description -->
        <p class="mt-6 text-gray-300 text-lg leading-8 max-w-2xl">
          {subtitle}
        </p>

        <!-- Call-to-action buttons -->
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href={primaryCtaHref}
            class="inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold text-gray-900 bg-white hover:bg-gray-100 transition"
          >
            {primaryCtaText}
          </a>
          <a
            href={secondaryCtaHref}
            class="inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold ring-1 ring-white/30 text-white hover:bg-white/10 transition"
          >
            {secondaryCtaText}
          </a>
        </div>
      </div>

      <!-- RIGHT SIDE: Club logo or illustration -->
      <div class="relative mx-auto flex h-90 w-90 items-center justify-center sm:h-80 sm:w-80 lg:h-[40rem] lg:w-[40rem]">
        <!-- Background glow effect -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-purple-400/40 to-green-500/40 blur-3xl" aria-hidden="true"></div>
        
        <!-- Logo container -->
        <div class="relative rounded-3xl bg-white/5 p-8 ring-1 ring-white/10 backdrop-blur">
          <img
            src={logoSrc}
            alt="UBC Game Dev logo"
            class="h-80 w-80 object-contain sm:h-52 sm:w-52 lg:h-100 lg:w-100"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Subtle bottom vignette for visual depth -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-white/0 via-white/0 to-black/20"></div>
</section>
