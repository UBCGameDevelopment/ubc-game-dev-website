---
interface Props {
  text: string;
  speed?: number; // seconds per loop
  direction?: "left" | "right";
  color?: string; // CSS variable or class
  className?: string;
  opacity?: string;
}

const {
  text,
  speed = 40,
  direction = "left",
  color = "var(--text-muted)",
  className = "",
  opacity = "0.05",
} = Astro.props;

const content = `${text} /// ${text} /// ${text} /// ${text} /// `;
---

<div class={`pointer-events-none opacity-[${opacity}] mix-blend-overlay select-none overflow-hidden ${className}`}>
  <div
    class={`cyber-marquee-track inline-flex w-max whitespace-nowrap ${direction === "right" ? "cyber-marquee-track-right" : ""}`}
    style={{
      "--marquee-duration": `${speed}s`,
      color: color,
    }}
  >
    <div class="flex shrink-0">
      <span class="px-4 text-[10rem] font-black tracking-widest uppercase">{content}</span>
    </div>
    <div
      class="flex shrink-0"
      aria-hidden="true"
    >
      <span class="px-4 text-[10rem] font-black tracking-widest uppercase">{content}</span>
    </div>
  </div>
</div>

<style>
  .cyber-marquee-track {
    animation: cyber-marquee-left var(--marquee-duration) linear infinite;
    will-change: transform;
  }

  .cyber-marquee-track-right {
    animation-name: cyber-marquee-right;
  }

  @keyframes cyber-marquee-left {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes cyber-marquee-right {
    from {
      transform: translate3d(-50%, 0, 0);
    }
    to {
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cyber-marquee-track,
    .cyber-marquee-track-right {
      animation: none;
      transform: none;
    }
  }
</style>
