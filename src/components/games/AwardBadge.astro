---
export interface Props {
    award: string;
}

const { award } = Astro.props;
---

<div class="mt-6">
    <div class="relative inline-block">
        <div class="from-accent-500 to-accent-600 absolute -inset-1 rounded-xl bg-gradient-to-r opacity-40 blur"></div>
        <div
            class="border-accent-500/50 from-accent-500/20 to-accent-600/10 relative rounded-xl border bg-gradient-to-br px-4 py-3 backdrop-blur-sm">
            <div class="flex items-center gap-2">
                <svg
                    class="text-accent-500 h-5 w-5"
                    fill="currentColor"
                    viewBox="0 0 20 20">
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                    </path>
                </svg>
                <div>
                    <div class="text-accent-300 text-xs font-medium tracking-wide uppercase">Award Winner</div>
                    <div class="text-sm font-bold text-white">{award}</div>
                </div>
            </div>
        </div>
    </div>
</div>
