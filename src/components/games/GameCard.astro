---
import type { Game } from "../../data/games";
import GameBadge from "./GameBadge.astro";
import GameTitle from "./GameTitle.astro";
import GameMedia from "./GameMedia.astro";
import AwardBadge from "./AwardBadge.astro";
import TeamMembers from "./TeamMembers.astro";

export interface Props extends Game {}
const { name, description, media, gameLink, teamMembers, award } = Astro.props;

// Generate unique ID for this card's media controls
const cardId = `game-${name.toLowerCase().replace(/\s+/g, "-")}`;
---

<article class="group relative">
  <!-- Gradient glow effect -->
  <div
    class="from-brand-700 via-brand-500 to-accent-500 absolute -inset-0.5 rounded-3xl bg-gradient-to-r opacity-20 blur transition-opacity duration-500 group-hover:opacity-30">
  </div>

  <!-- Main card container -->
  <div
    class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.08] to-white/[0.02] shadow-2xl ring-1 shadow-black/40 ring-white/10 backdrop-blur-xl">
    <!-- Decorative background elements -->
    <div class="bg-brand-500/5 absolute top-0 right-0 h-64 w-64 rounded-full blur-3xl"></div>
    <div class="bg-accent-500/5 absolute bottom-0 left-0 h-72 w-72 rounded-full blur-3xl"></div>

    <div class="relative z-10 p-6 md:p-8">
      <!-- Top Section: Grid Layout -->
      <div class="grid items-center gap-8 md:grid-cols-2">
        <!-- Left Section: Game Info -->
        <div class="flex flex-col">
          <div class="flex-1">
            <GameBadge />
            <GameTitle
              name={name}
              gameLink={gameLink}
            />

            <p class="text-sm leading-relaxed text-gray-50/80 md:text-base">
              {description}
            </p>
          </div>

          {award && <AwardBadge award={award} />}
        </div>

        <!-- Right Section: Media & Team -->
        <div class="flex h-fit flex-col gap-4">
          <GameMedia
            media={media}
            name={name}
            cardId={cardId}
          />
          {teamMembers && teamMembers.length > 0 && <TeamMembers members={teamMembers} />}
        </div>
      </div>
    </div>
  </div>
</article>
