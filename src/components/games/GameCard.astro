---
import type { Game } from "../../types";
import BaseCard from "../common/Card/BaseCard.astro";
import Badge from "../common/Badge/Badge.astro";
import GameTitle from "./GameTitle.astro";
import GameMedia from "./GameMedia.astro";
import AwardBadge from "./AwardBadge.astro";
import TeamMembers from "./TeamMembers.astro";

export interface Props extends Game {}
const { name, description, media, gameLink, teamMembers, award } = Astro.props;

// Generate unique ID for this card's media controls
const cardId = `game-${name.toLowerCase().replace(/\s+/g, "-")}`;
---

<BaseCard>
  <div class="p-6 md:p-8">
    <!-- Top Section: Grid Layout -->
    <div class="grid items-center gap-8 md:grid-cols-2">
      <!-- Left Section: Game Info -->
      <div class="flex flex-col">
        <div class="flex-1">
          <Badge
            label="Game"
            variant="game"
            class="mb-4 px-3 py-1"
          />
          <GameTitle
            name={name}
            gameLink={gameLink}
          />

          <p class="text-sm leading-relaxed text-gray-50/80 md:text-base">
            {description}
          </p>
        </div>

        {award && <AwardBadge award={award} />}
      </div>

      <!-- Right Section: Media & Team -->
      <div class="flex h-fit flex-col gap-4">
        <GameMedia
          media={media}
          name={name}
          cardId={cardId}
        />
        {teamMembers && teamMembers.length > 0 && <TeamMembers members={teamMembers} />}
      </div>
    </div>
  </div>
</BaseCard>
