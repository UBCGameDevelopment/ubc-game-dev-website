---
interface Props {
  years: string[];
}

const { years } = Astro.props;
---

<aside class="h-fit w-full shrink-0 md:sticky md:top-32 md:w-64">
  <div class="hud-card border border-[var(--border-dim)] bg-[var(--bg-panel)]/80 p-6 backdrop-blur-md">
    <h2 class="mb-6 border-b border-[var(--border-dim)] pb-4 text-xl font-black tracking-widest text-white uppercase">
      Club Timeline
    </h2>

    <nav class="space-y-2">
      {
        years.map((year) => (
          <a
            href={`#year-${year}`}
            class="font-tech block w-full rounded px-4 py-3 text-left tracking-wider text-[var(--text-muted)] transition-all hover:border-l-2 hover:border-[var(--cyber-yellow)] hover:bg-[var(--bg-deep)] hover:text-white"
          >
            <span class="mr-2 text-[var(--cyber-yellow)]">//</span> {year}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="mt-8 hidden md:block">
    <div class="font-tech text-xs text-[var(--border-dim)]">
      <p>SYS.STATUS: ONLINE</p>
      <p>ARCHIVE_ACCESS: GRANTED</p>
    </div>
  </div>
</aside>
