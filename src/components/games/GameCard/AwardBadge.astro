---
export interface Props {
  award: string;
}

const { award } = Astro.props;
---

<div class="mt-6">
  <div class="relative inline-block">
    <div
      class="relative flex items-center gap-3 border border-[var(--cyber-yellow)] bg-[var(--surface-2)] px-4 py-3 shadow-[0_0_15px_rgba(252,238,10,0.2)]"
      style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
    >
      <div
        class="flex h-8 w-8 items-center justify-center bg-[var(--cyber-yellow)] text-[var(--surface)]"
        style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
      >
        <svg
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
          >
          </path>
        </svg>
      </div>
      <div>
        <div class="font-pixel text-[10px] font-bold tracking-widest text-[var(--cyber-yellow)] uppercase">
          Award Winner
        </div>
        <div class="text-sm font-bold text-white">{award}</div>
      </div>
    </div>
  </div>
</div>
