---
export interface Props {
  members: string[];
}

const { members } = Astro.props;
---

<div class="rounded-xl border border-[var(--border)] bg-[var(--surface-2)] p-4 shadow-sm">
  <div class="mb-2 flex items-center gap-2">
    <svg
      class="h-4 w-4 text-[var(--brand)]"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
      >
      </path>
    </svg>
    <h4 class="text-xs font-semibold tracking-wide text-[var(--brand)] uppercase">Team Members</h4>
  </div>
  <div class="flex flex-wrap gap-2">
    {
      members.map((member) => (
        <span class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--surface-3)] px-2.5 py-1 text-xs font-medium text-[var(--text-muted)]">
          {member}
        </span>
      ))
    }
  </div>
</div>
