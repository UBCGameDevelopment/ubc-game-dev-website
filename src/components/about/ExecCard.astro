---
import { Image } from 'astro:assets';
import type { Exec } from '../../data/execs';

export interface Props extends Exec {}

const { name, role, linkedin, github, image } = Astro.props;
---

<div class="group flex flex-col items-center text-center">
  <!-- Photo with hover effect -->
  <div class="relative">
    <!-- Glow effect on hover -->
    <div class="absolute -inset-2 bg-gradient-to-r from-brand-500 to-accent-500 rounded-full blur-xl opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
    
    <div class="relative">
      <Image
        src={image}
        alt={`${name} headshot`}
        width={512}
        height={512}
        quality={99}
        format="webp"
        class="h-32 w-32 md:h-36 md:w-36 rounded-full object-cover ring-2 ring-white/20 group-hover:ring-brand-400/60 shadow-xl group-hover:shadow-2xl group-hover:shadow-brand-500/20 transition-all duration-300 group-hover:scale-105"
        loading="lazy"
      />

      {/* LinkedIn badge overlay */}
      <div class="absolute -bottom-2 -right-2 w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center ring-2 ring-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <a
          href={linkedin}
          target="_blank"
          rel="noreferrer noopener"
          class="flex items-center justify-center w-full h-full"
          aria-label={`LinkedIn profile for ${name}`}
          title="LinkedIn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="white"
            class="h-5 w-5"
          >
            <path d="M20.45 20.45h-3.55v-5.58c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.62-1.85 3.34-1.85 3.57 0 4.23 2.35 4.23 5.4v6.34zM5.34 7.44a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>
          </svg>
        </a>
      </div>

      {/* GitHub badge overlay */}
      {github && (
        <div class="absolute -bottom-2 -left-2 w-10 h-10 rounded-full bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center ring-2 ring-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <a
            href={github}
            target="_blank"
            rel="noreferrer noopener"
            class="flex items-center justify-center w-full h-full"
            aria-label={`GitHub profile for ${name}`}
            title="GitHub"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="white"
              class="h-5 w-5"
            >
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.54.5.09.68-.22.68-.49 0-.24-.01-1.05-.01-1.9-2.78.6-3.37-1.34-3.37-1.34-.45-1.14-1.1-1.44-1.1-1.44-.9-.61.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.64.35-1.08.64-1.33-2.22-.25-4.56-1.11-4.56-4.93 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.57 9.57 0 0112 4.5c.84 0 1.68.11 2.47.32 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.82-2.34 4.68-4.56 4.93.36.31.68.92.68 1.85 0 1.34-.01 2.43-.01 2.77 0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Name / Role -->
  <div class="mt-5">
    <div class="text-lg md:text-xl font-extrabold tracking-wide group-hover:text-brand-400 transition-colors duration-300">{name}</div>
    <div class="text-sm md:text-base text-gray-300 mt-1 font-medium">{role}</div>
  </div>
</div>
