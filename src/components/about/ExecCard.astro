---
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  role: string;
  linkedin: string;
  image: ImageMetadata;
}

const { name, role, linkedin, image } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <!-- Photo -->
  <Image
    src={image}
    alt={`${name} headshot`}
    width={512}
    height={512}
    quality={99}
    format="webp"
    class="h-28 w-28 md:h-32 md:w-32 rounded-full object-cover ring-1 ring-white/15 shadow-lg"
    loading="lazy"
  />

  <!-- Name / Role -->
  <div class="mt-4">
    <div class="text-lg md:text-xl font-extrabold tracking-wide">{name}</div>
    <div class="text-sm md:text-base text-gray-200">{role}</div>
  </div>

  <!-- LinkedIn Icon -->
  <div class="mt-2">
    <a
      href={linkedin}
      target="_blank"
      rel="noreferrer noopener"
      class="inline-flex items-center gap-2 text-sm md:text-base hover:text-[var(--brand)] transition"
      aria-label={`LinkedIn profile for ${name}`}
      title="LinkedIn"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-5 w-5"
      >
        <path d="M20.45 20.45h-3.55v-5.58c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.62-1.85 3.34-1.85 3.57 0 4.23 2.35 4.23 5.4v6.34zM5.34 7.44a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"/>
      </svg>
      <span class="sr-only">LinkedIn</span>
    </a>
  </div>
</div>
