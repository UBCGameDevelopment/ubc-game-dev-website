---
// src/components/about/ExecGrid.astro
import ExecCard from "./ExecCard.astro";
import type { Exec } from "../../data/execs";

export interface Props { execs: Exec[] }

const { execs } = Astro.props;

// Find a single President; keep the rest in original order
const presidentIndex = execs.findIndex(e => e.role === "President");
const president = presidentIndex >= 0 ? execs[presidentIndex] : null;
const rest = execs.filter((_, i) => i !== presidentIndex);
---

<section class="container-page my-16 md:my-20">
  <!-- Section Header -->
  <div class="text-center max-w-3xl mx-auto mb-12">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-500/20 border border-brand-500/30 mb-4">
      <span class="text-sm font-semibold text-brand-400">Meet The Team</span>
    </div>
    
    <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-white via-gray-100 to-gray-300 bg-clip-text text-transparent">
      Our Executive Team
    </h2>
    <p class="mt-4 text-lg text-gray-50/80 leading-relaxed">
      Meet the folks who keep UBC Game Dev running—events, workshops, and community!
    </p>
  </div>

  <!-- President row with special styling -->
  {president && (
    <div class="mt-12 flex justify-center">
      <div class="relative group">
        {/* Glow effect for president */}
        <div class="absolute -inset-4 bg-gradient-to-r from-brand-500 to-accent-500 rounded-full blur-2xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
        <div class="relative w-[200px] md:w-[220px]"> 
          <ExecCard {...president} />
        </div>
      </div>
    </div>
  )}

  <!-- Rest of execs in a modern grid -->
  <div class="mt-16 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-10 max-w-6xl mx-auto">
    {rest.map((e) => (
      <div class="flex justify-center">
        <div class="w-full max-w-[180px] md:max-w-[200px]"> 
          <ExecCard {...e} />
        </div>
      </div>
    ))}
  </div>
</section>
