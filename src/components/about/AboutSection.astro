---
/** Static "About" content with three parts:
 *  - Our Mission -> MAIN QUEST
 *  - How It Works -> GUILD STRUCTURE
 *  - Join Us -> JOIN THE PARTY
 */
import PixelBadge from "../common/PixelBadge.astro";
---

<section class="container-page pt-32 pb-10 md:pb-14">
  <div class="relative">
    <!-- Atmospheric Cyber Background -->
    <div class="pointer-events-none fixed inset-0 z-0">
      <!-- Deep Void Base -->
      <div class="absolute inset-0 bg-[#030014]"></div>

      <!-- City Lights Glow (Reference: Red Tower, Blue Signs) -->
      <div
        class="absolute top-[-20%] right-[-10%] h-[800px] w-[800px] rounded-full bg-[var(--cyber-red)] opacity-[0.15] mix-blend-screen blur-[150px]"
        style="animation: glow-pulse 8s infinite alternate;"
      >
      </div>
      <div
        class="absolute bottom-[-20%] left-[-10%] h-[800px] w-[800px] rounded-full bg-[var(--cyber-blue)] opacity-[0.12] mix-blend-screen blur-[150px]"
        style="animation: glow-pulse 10s infinite alternate-reverse;"
      >
      </div>
      <div
        class="absolute top-[30%] left-[20%] h-[600px] w-[600px] rounded-full bg-[var(--brand)] opacity-[0.08] blur-[120px]"
      >
      </div>

      <!-- Digital Rain / Vertical Texture -->
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, .3) 25%, rgba(255, 255, 255, .3) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .3) 75%, rgba(255, 255, 255, .3) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, .3) 25%, rgba(255, 255, 255, .3) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .3) 75%, rgba(255, 255, 255, .3) 76%, transparent 77%, transparent); background-size: 50px 50px;"
      >
      </div>

      <!-- Vignette & Fog -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#030014_90%)]"></div>
    </div>

    <!-- MAIN QUEST (Mission) -->
    <div class="relative mb-24 text-center">
      <div class="mb-6 inline-flex justify-center">
        <PixelBadge
          label="Current Objective"
          variant="brand"
        />
      </div>

      <h1 class="font-pixel text-neon text-4xl tracking-widest uppercase md:text-6xl lg:text-7xl">
        UBC <span class="text-[var(--cyber-yellow)]">GAME DEV</span>
      </h1>
      <p class="font-pixel mt-4 text-xl tracking-widest text-[var(--accent)] uppercase">The Main Quest</p>

      <div
        class="hero-terminal glow-pulse mx-auto mt-12 max-w-4xl border border-[var(--brand)]/40 bg-[var(--surface)]/90 p-8 shadow-[0_0_30px_-5px_var(--brand)] backdrop-blur-lg md:p-12"
        style="clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);"
      >
        <p class="font-mono text-lg leading-relaxed text-[var(--text-muted)] md:text-2xl">
          "To equip every student with the tools, knowledge, and party members needed to craft their own legendary video
          games."
        </p>
        <div class="mt-8 flex justify-center gap-3">
          <div class="h-2 w-2 animate-pulse bg-[var(--brand)]"></div>
          <div
            class="h-2 w-2 animate-pulse bg-[var(--brand)]"
            style="animation-delay: 0.2s;"
          >
          </div>
          <div
            class="h-2 w-2 animate-pulse bg-[var(--brand)]"
            style="animation-delay: 0.4s;"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- GUILD STRUCTURE (How It Works) -->
    <div class="relative mb-24">
      <h2 class="font-pixel text-neon mb-12 text-center text-3xl tracking-widest uppercase md:text-4xl">
        Guild <span class="text-[var(--cyber-yellow)]">Structure</span>
      </h2>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- Class: Project Teams -->
        <div
          class="holo-card group relative overflow-hidden border border-[var(--brand)]/30 bg-[var(--surface)]/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-[var(--brand)] hover:shadow-[0_0_30px_rgba(168,85,247,0.25)]"
          style="clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);"
        >
          <div class="absolute top-0 right-0 p-4 opacity-10 transition-opacity group-hover:opacity-20">
            <svg
              class="h-32 w-32"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2L2 7l10 5 10-5-10-5zm0 9l2.5-1.25L12 8.5l-2.5 1.25L12 11zm0 2.5l-5-2.5-5 2.5L12 22l10-8.5-5-2.5-5 2.5z"
              >
              </path>
            </svg>
          </div>

          <div class="p-8">
            <div class="mb-4">
              <PixelBadge
                label="Class: Vanguard"
                variant="brand"
              />
            </div>
            <h3 class="font-pixel text-neon mb-4 text-2xl">Project Teams</h3>
            <p class="leading-relaxed text-[var(--text-muted)]">
              Elite squads led by veteran developers. These parties are balanced with diverse skill sets—programmers,
              artists, and designers—working together to ship original titles.
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                High EXP
              </span>
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                Teamwork
              </span>
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                Shipped Games
              </span>
            </div>
          </div>
        </div>

        <!-- Class: Learning Community -->
        <div
          class="holo-card group relative overflow-hidden border border-[var(--accent)]/30 bg-[var(--surface)]/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-[var(--accent)] hover:shadow-[0_0_30px_rgba(232,121,249,0.25)]"
          style="clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);"
        >
          <div class="absolute top-0 right-0 p-4 opacity-10 transition-opacity group-hover:opacity-20">
            <svg
              class="h-32 w-32"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M12 14l9-5-9-5-9 5 9 5z"></path><path
                d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
              >
              </path><path
                d="M12 14l-5-2.778v5.556l5 2.778 5-2.778v-5.556L12 14z"
                opacity=".5"
              >
              </path>
            </svg>
          </div>

          <div class="p-8">
            <div class="mb-4">
              <PixelBadge
                label="Class: Recruit"
                variant="accent"
              />
            </div>
            <h3 class="font-pixel text-neon-accent mb-4 text-2xl">Learning Community</h3>
            <p class="leading-relaxed text-[var(--text-muted)]">
              The training grounds for aspiring devs. A safe zone to grind skills, experiment with mechanics, and find
              future party members. No prior level requirement.
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                Workshops
              </span>
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                Socials
              </span>
              <span
                class="rounded border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-[10px] text-[var(--text-muted)] uppercase"
              >
                Networking
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- JOIN THE PARTY -->
    <div
      class="hero-terminal relative overflow-hidden border border-[var(--brand)]/40 bg-[var(--surface)]/80 p-12 text-center shadow-[0_0_30px_-5px_var(--brand)] backdrop-blur-lg"
      style="clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);"
    >
      <h2 class="font-pixel text-neon mb-6 text-3xl tracking-widest uppercase">Ready to Join the Party?</h2>
      <p class="mx-auto mb-8 max-w-2xl font-mono text-lg text-[var(--text-muted)]">
        Whether you're a LVL 1 Beginner or a LVL 99 Expert, there's a spot for you in our guild. Equip your creativity
        and start your adventure today.
      </p>

      <a
        href="/contact"
        class="box-neon glow-pulse group relative inline-flex items-center gap-3 overflow-hidden bg-[var(--brand)] px-8 py-4 font-bold text-white transition-all hover:scale-105"
        style="clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);"
      >
        <span class="font-pixel relative z-10 tracking-wider">PRESS START</span>
        <svg
          class="relative z-10 h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
          >
          </path><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          >
          </path>
        </svg>
      </a>
    </div>
  </div>
</section>
