---
/**
 * Infinite, hover-to-pause logo slider.
 * - Transparent background (no white band)
 * - Logos normalized to same visual size (fixed height box, max width)
 * - Works with mixed aspect ratios (object-contain)
 *
 * Props:
 *   logos: Array<{ src: ImageMetadata, alt: string, href?: string }>
 *   height?: number    // logo box height in px (default 80)
 *   maxWidth?: number  // max per-logo width in px (default 200)
 *   speed?: "slow" | "normal" | "fast"
 *   gap?: number       // gap between logos in px (default 72)
 */
 export interface Logo { src: ImageMetadata; alt: string; href?: string }
export interface Props {
  logos: Logo[];
  height?: number;
  maxWidth?: number;
  speed?: "slow" | "normal" | "fast";
  gap?: number;
}

const {
  logos,
  height = 80,
  maxWidth = 200,
  speed = "normal",
  gap = 72,
} = Astro.props;

const speedMs = speed === "slow" ? 28000 : speed === "fast" ? 12000 : 18000;
---

<section class="logo-slider" style={`--h:${height}px; --w:${maxWidth}px; --gap:${gap}px; --dur:${speedMs}ms`}>
  <div class="slider-outer">
    <div class="slider-track">
      {logos.map((l) => (
        l.href ? (
          <a class="logo" href={l.href} target="_blank" rel="noreferrer noopener">
            <img src={l.src.src} alt={l.alt} height={height} loading="lazy" />
          </a>
        ) : (
          <div class="logo">
            <img src={l.src.src} alt={l.alt} height={height} loading="lazy" />
          </div>
        )
      ))}
      {logos.map((l) => (
        l.href ? (
          <a class="logo" href={l.href} target="_blank" rel="noreferrer noopener" aria-hidden="true" tabindex="-1">
            <img src={l.src.src} alt="" height={height} loading="lazy" />
          </a>
        ) : (
          <div class="logo" aria-hidden="true">
            <img src={l.src.src} alt="" height={height} loading="lazy" />
          </div>
        )
      ))}
    </div>

    <!-- transparent edge fades that blend with page bg -->
    <div class="fade left" aria-hidden="true"></div>
    <div class="fade right" aria-hidden="true"></div>
  </div>
</section>

<style>
.logo-slider {
  /* use your site's surface token so fades blend with the gradient */
  --surface: var(--surface, rgba(0,0,0,0)); /* from global.css if present */
  position: relative;
  padding-block: 18px; /* space above/below logos */
  background: transparent; 
}

/* mask + overflow to keep it tidy */
.slider-outer {
  position: relative;
  overflow: hidden;
  height: calc(var(--h) + 6px);
  /* soften edges without a visible band */
  mask-image: linear-gradient(to right,
      transparent, black 10%, black 90%, transparent);
  -webkit-mask-image: linear-gradient(to right,
      transparent, black 10%, black 90%, transparent);
}

.slider-track {
  display: flex;
  align-items: center;
  gap: var(--gap);
  width: max-content;
  animation: scroll var(--dur) linear infinite;
}
.slider-outer:hover .slider-track { animation-play-state: paused; }

.logo {
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  height: var(--h);
  max-width: var(--w);   /* ✅ cap wide logos */
  width: var(--w);       /* fixed box so rows look even */
}

/* normalize all logos */
.logo img {
  max-height: 100%;
  max-width: 100%;
  width: auto;
  height: auto;
  object-fit: contain;   /* ✅ square/rect scale correctly */
  transition: transform .2s ease, opacity .2s ease;
  opacity: .95;
}
.logo:hover img { transform: translateY(-2px); opacity: 1; }

/* transparent edge fades (blend to page background) */
.fade {
  pointer-events: none;
  position: absolute; inset-block: 0; width: 8%;
}
.fade.left  { left: 0;  background: linear-gradient(to right, var(--surface), transparent); }
.fade.right { right: 0; background: linear-gradient(to left,  var(--surface), transparent); }

@keyframes scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); } /* track is duplicated */
}

/* small screens */
@media (max-width: 480px) {
  .logo-slider { padding-block: 12px; }
  .slider-track { gap: 40px; }
}
</style>
