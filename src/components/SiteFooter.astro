---
export interface Social { label: string; href: string; external?: boolean; }
export interface Props { socials?: Social[] }
const { socials = [] } = Astro.props;
---

<footer class="mt-16">
  <div class="container-page">
    <h3 class="text-center text-base md:text-lg font-semibold tracking-wide">
      Follow Us on Social Media
    </h3>

    <ul class="mt-4 flex flex-wrap items-center justify-center gap-4 md:gap-6">
      {socials.map((s) => (
        <li>
          <a href={s.href}
             {...(s.external ? { target: "_blank", rel: "noreferrer noopener" } : {})}
             class="inline-flex h-10 w-10 items-center justify-center rounded-full
                    border border-white/15 bg-white/[0.06] hover:bg-white/[0.12] transition
                    text-sm font-semibold"
             aria-label={s.label} title={s.label}>
            {s.label[0]}
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-5 text-center text-xs text-gray-400">
      © {new Date().getFullYear()} UBC Game Development. All rights reserved.
    </p>
  </div>
</footer>
