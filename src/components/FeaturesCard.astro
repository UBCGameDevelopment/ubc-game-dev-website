---
export interface Props {
  title: string;
  children?: any;     // description goes in slot
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  cta?: string;
}

const { title, imageSrc, imageAlt = "", href, cta = "Learn More" } = Astro.props;
---

<article
  class="rounded-3xl border border-white/15 bg-white/[0.04] backdrop-blur-xl
         shadow-2xl shadow-black/50 p-6 md:p-8 flex flex-col gap-5"
>
  <h3 class="text-2xl font-extrabold tracking-wide">{title}</h3>

  <div class="text-[0.98rem] leading-relaxed text-gray-50/85">
    <slot />
  </div>

  {imageSrc && (
    <img
      src={imageSrc}
      alt={imageAlt}
      loading="lazy"
      class="rounded-xl border border-white/10 object-cover max-h-36"
    />
  )}

  {href && (
    <div class="mt-2">
      <a href={href} class="btn btn-outline rounded-full px-5 py-2">
        {cta}
      </a>
    </div>
  )}
</article>
