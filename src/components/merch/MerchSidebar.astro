---
import MerchFilters from "./MerchFilters.astro";

interface Props {
  categories: ReadonlyArray<{ id: string; label: string }>;
}

const { categories } = Astro.props;
---

<aside
  class="hud-card h-fit border border-[var(--border-dim)] bg-[var(--bg-panel)]/80 pb-8 text-sm shadow-[0_0_30px_rgba(0,0,0,0.55)] backdrop-blur"
>
  <div class="border-b border-[var(--border-dim)] bg-[var(--bg-deep)] px-5 py-4">
    <p class="font-tech text-xs tracking-[0.25em] text-[var(--text-muted)] uppercase">Outfit Console // v3.2</p>
  </div>
  <MerchFilters categories={categories} />

  <div class="mt-8 px-5">
    <div class="hud-card border border-[var(--border-dim)] bg-[var(--bg-deep)]/70 p-4">
      <p
        class="font-tech text-xs tracking-widest text-[var(--cyber-blue)] uppercase [text-shadow:0_0_10px_rgba(0,240,255,0.6),0_0_20px_rgba(0,240,255,0.4)]"
      >
        Operator Status
      </p>
      <div class="mt-3 space-y-2 text-[10px] text-[var(--text-muted)]">
        <div class="flex items-center justify-between">
          <span>Credits</span>
          <span
            class="text-[var(--cyber-blue)] [text-shadow:0_0_10px_rgba(0,240,255,0.8),0_0_20px_rgba(0,240,255,0.6)]"
          >
            READY
          </span>
        </div>
        <div class="flex items-center justify-between">
          <span>Inventory</span>
          <span class="text-[var(--brand)] [text-shadow:0_0_10px_rgba(168,85,247,0.8),0_0_20px_rgba(168,85,247,0.6)]">
            SYNCED
          </span>
        </div>
        <div class="flex items-center justify-between">
          <span>Drop Rate</span>
          <span
            class="text-[var(--cyber-yellow)] [text-shadow:0_0_10px_rgba(252,238,10,0.8),0_0_20px_rgba(252,238,10,0.6)]"
          >
            ACTIVE
          </span>
        </div>
      </div>
    </div>
  </div>
</aside>
