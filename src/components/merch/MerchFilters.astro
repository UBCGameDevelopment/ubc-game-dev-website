---
interface Props {
  categories: ReadonlyArray<{ id: string; label: string }>;
}

const { categories } = Astro.props;
---

<div class="mt-4 flex flex-col gap-2 px-4">
  <button
    data-category="all"
    class="filter-btn active loadout-btn"
  >
    <span>All Items</span>
    <span class="loadout-btn-indicator">//</span>
  </button>
  {
    categories
      .filter((c) => c.id !== "all")
      .map((cat) => (
        <button
          data-category={cat.id}
          class="filter-btn loadout-btn"
        >
          <span>{cat.label}</span>
          <span class="loadout-btn-indicator">//</span>
        </button>
      ))
  }
</div>

<style>
  .loadout-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    border: 1px solid var(--border-dim);
    padding: 12px 16px 12px 20px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(5, 5, 8, 0.6);
    color: var(--text-muted);
    transition: all 0.2s ease;
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
  }

  .loadout-btn:hover {
    border-color: var(--brand);
    color: white;
    background: rgba(10, 10, 12, 0.8);
  }

  .loadout-btn-indicator {
    color: var(--cyber-yellow);
    opacity: 0.6;
  }

  .filter-btn.active {
    background: var(--cyber-yellow);
    color: #050505;
    border-color: var(--cyber-yellow);
    box-shadow: 0 0 15px rgba(252, 238, 10, 0.3);
  }

  .filter-btn.active .loadout-btn-indicator {
    color: #050505;
    opacity: 1;
  }
</style>
