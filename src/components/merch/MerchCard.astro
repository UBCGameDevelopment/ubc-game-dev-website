---
import type { MerchItem } from "../../data/merch";

export interface Props extends MerchItem {}

const { name, description, price, category, isNew, isSoldOut, colors, sizes, images } = Astro.props;

// Filter out placeholder images
const isPlaceholder = (src: string) => src.includes("/placeholder-") || src.includes("placeholder.");
const imageList = (images ?? []).filter((src) => !isPlaceholder(src));
---

<div
  data-merch-data={JSON.stringify(Astro.props)}
  onclick="window.dispatchEvent(new CustomEvent('open-merch-modal', { detail: JSON.parse(this.dataset.merchData) }))"
  class:list={[
    "group merch-hud-card relative flex h-full cursor-pointer flex-col overflow-hidden transition-all duration-300",
    isSoldOut ? "opacity-70 grayscale" : "hover:shadow-[0_0_35px_rgba(0,240,255,0.2)]",
  ]}
>
  <div class="scanline-soft pointer-events-none absolute inset-0 z-0 opacity-10"></div>
  <!-- Badges -->
  <div class="absolute top-0 left-0 z-10 flex flex-col gap-2 p-0">
    {
      isNew && !isSoldOut && (
        <span
          class="bg-[var(--cyber-yellow)] px-3 py-1 text-[10px] font-bold tracking-[0.2em] text-black uppercase shadow-[0_0_12px_rgba(252,238,10,0.35)]"
          style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 8px));"
        >
          NEW ARRIVAL
        </span>
      )
    }
    {
      isSoldOut && (
        <span
          class="bg-[var(--bg-panel)] px-3 py-1 text-[10px] font-bold tracking-[0.2em] text-[var(--text-muted)] uppercase"
          style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 8px));"
        >
          SOLD OUT
        </span>
      )
    }
  </div>

  <!-- Image -->
  <div
    class="relative aspect-square overflow-hidden bg-[radial-gradient(circle_at_30%_20%,rgba(0,240,255,0.15)_0%,rgba(0,0,0,0.6)_55%)]"
  >
    {
      imageList.length > 0 ? (
        <>
          <div
            class="absolute inset-0"
            data-merch-carousel={imageList.length > 1 ? "true" : "false"}
          >
            {imageList.map((src, index) => (
              <img
                src={src}
                alt={`${name} image ${index + 1}`}
                loading="lazy"
                data-carousel-slide
                class:list={[
                  "absolute inset-0 h-full w-full object-cover transition-opacity duration-500",
                  index === 0 ? "opacity-100" : "opacity-0",
                ]}
              />
            ))}

            {imageList.length > 1 && (
              <>
                {/* Navigation buttons */}
                <button
                  data-carousel-prev
                  class="absolute top-1/2 left-3 z-20 -translate-y-1/2 rounded-full bg-black/60 p-3 text-white backdrop-blur-sm transition-all hover:scale-110 hover:bg-black/80"
                  aria-label="Previous image"
                >
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 19l-7-7 7-7"
                    />
                  </svg>
                </button>
                <button
                  data-carousel-next
                  class="absolute top-1/2 right-3 z-20 -translate-y-1/2 rounded-full bg-black/60 p-3 text-white backdrop-blur-sm transition-all hover:scale-110 hover:bg-black/80"
                  aria-label="Next image"
                >
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </button>
                {/* Dots indicator */}
                <div class="absolute bottom-3 left-1/2 z-20 flex -translate-x-1/2 items-center gap-1.5 rounded-full bg-black/45 px-2 py-1 backdrop-blur-sm">
                  {imageList.map((_, index) => (
                    <span
                      data-carousel-dot
                      class:list={[
                        "h-1.5 w-1.5 rounded-full transition-all duration-300",
                        index === 0 ? "w-3 bg-white" : "bg-white/45",
                      ]}
                    />
                  ))}
                </div>
              </>
            )}
          </div>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
          <span class="font-tech absolute bottom-2 left-2 z-10 rounded bg-black/50 px-1.5 py-0.5 text-[8px] tracking-wider text-white/40 backdrop-blur-sm">
            AI Generated Image
          </span>
        </>
      ) : (
        <div class="flex h-full w-full items-center justify-center p-8">
          <svg
            class:list={[
              "h-24 w-24 drop-shadow-[0_0_18px_rgba(0,240,255,0.4)] transition-transform duration-500",
              !isSoldOut && "group-hover:scale-110 group-hover:rotate-3",
              isSoldOut ? "text-[var(--text-muted)]/30" : "text-[var(--cyber-blue)]",
            ]}
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            {category === "apparel" && (
              <path d="M21.6 18.2L13 11.75v-.91a3.496 3.496 0 00-.18-6.75A3.51 3.51 0 008.5 7.06h3c0-.85.58-1.56 1.36-1.77L12 7.06V7c0 .55.45 1 1 1s1-.45 1-1v-.06h0c.85 0 1.5.65 1.5 1.5s-.65 1.5-1.5 1.5h-4c-.55 0-1 .45-1 1s.45 1 1 1v.81l-8.6 6.45a2.5 2.5 0 003 4l5.1-3.83v4.07c0 .55.45 1 1 1s1-.45 1-1v-4.07l5.1 3.83a2.5 2.5 0 003-4z" />
            )}
            {category === "accessories" && (
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z" />
            )}
            {category === "stickers" && (
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.17.01-.34.02-.5l5.48 2.28v1.22c0 1.1.9 2 2 2h1v2.93zm6.78-5.58c-.29-.08-.59-.15-.78-.15h-2v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V5.08c3.39.49 6 3.4 6 6.92 0 .97-.19 1.9-.54 2.75l.32.6z" />
            )}
          </svg>
        </div>
      )
    }

    <!-- Decorative corner accent -->
    {
      !isSoldOut && (
        <div class="absolute right-0 bottom-0 h-0.5 w-16 bg-[var(--cyber-yellow)] transition-all duration-300 group-hover:w-full" />
      )
    }
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col p-5">
    <!-- Category -->
    <div class="flex items-start justify-between">
      <span class="text-[10px] font-bold tracking-[0.3em] text-[var(--cyber-yellow)] uppercase">
        {category}
      </span>
      <div class="h-1 w-8 bg-[var(--border-dim)] transition-colors group-hover:bg-[var(--cyber-blue)]"></div>
    </div>

    <!-- Name -->
    <h3 class="font-pixel mt-2 text-lg text-white transition-colors group-hover:text-[var(--cyber-blue)]">
      {name}
    </h3>

    <!-- Description -->
    <p class="font-tech mt-2 line-clamp-2 text-sm text-[var(--text-muted)]">
      {description}
    </p>

    <!-- Options -->
    {
      colors && colors.length > 0 && (
        <div class="font-tech mt-3 flex items-center gap-2 text-[10px] tracking-widest text-[var(--text-muted)] uppercase">
          <span class="text-[var(--cyber-blue)]">></span>
          <span class="text-white">{colors.join(" / ")}</span>
        </div>
      )
    }
    {
      sizes && sizes.length > 0 && (
        <div class="font-tech mt-1 flex items-center gap-2 text-[10px] tracking-widest text-[var(--text-muted)] uppercase">
          <span class="text-[var(--cyber-blue)]">></span>
          <span class="text-white">{sizes.join(" / ")}</span>
        </div>
      )
    }

    <!-- Price & Action -->
    <div class="mt-auto flex flex-col gap-4 pt-6">
      <span class="font-pixel text-2xl text-[var(--cyber-yellow)] transition-colors group-hover:text-white">
        ${price} CAD
      </span>
      {
        !isSoldOut && (
          <button class="clip-angled group relative inline-flex items-center justify-center gap-2 overflow-hidden bg-[var(--cyber-blue)] px-5 py-2.5 text-xs font-bold tracking-[0.3em] text-black uppercase transition-all hover:-translate-y-1 hover:bg-white hover:shadow-[0_0_15px_var(--cyber-blue)]">
            <span class="relative z-10">Buy Now</span>
            <svg
              class="relative z-10 h-3 w-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"
              />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</div>

<script>
  const initializeMerchCardCarousels = () => {
    const carousels = document.querySelectorAll("[data-merch-carousel='true']");
    carousels.forEach((carousel) => {
      if (!(carousel instanceof HTMLElement) || carousel.dataset.carouselInitialized === "true") {
        return;
      }

      const slides = Array.from(carousel.querySelectorAll("[data-carousel-slide]"));
      const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]"));
      const prevButton = carousel.querySelector("[data-carousel-prev]");
      const nextButton = carousel.querySelector("[data-carousel-next]");

      if (slides.length < 2) {
        return;
      }

      carousel.dataset.carouselInitialized = "true";
      let activeIndex = 0;

      const setActive = (nextIndex: number) => {
        activeIndex = nextIndex;
        slides.forEach((slide, slideIndex) => {
          slide.classList.toggle("opacity-100", slideIndex === nextIndex);
          slide.classList.toggle("opacity-0", slideIndex !== nextIndex);
        });

        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle("w-3", dotIndex === nextIndex);
          dot.classList.toggle("bg-white", dotIndex === nextIndex);
          dot.classList.toggle("bg-white/45", dotIndex !== nextIndex);
        });
      };

      const goToNext = () => {
        const nextIndex = (activeIndex + 1) % slides.length;
        setActive(nextIndex);
      };

      const goToPrev = () => {
        const prevIndex = (activeIndex - 1 + slides.length) % slides.length;
        setActive(prevIndex);
      };

      // Add click listeners to navigation buttons
      if (nextButton) {
        nextButton.addEventListener("click", (e) => {
          e.stopPropagation(); // Prevent triggering the card click
          goToNext();
        });
      }

      if (prevButton) {
        prevButton.addEventListener("click", (e) => {
          e.stopPropagation(); // Prevent triggering the card click
          goToPrev();
        });
      }
    });
  };

  initializeMerchCardCarousels();
  document.addEventListener("astro:page-load", initializeMerchCardCarousels);
</script>
