---
import type { MerchItem } from "../../data/merch";

export interface Props extends MerchItem {}

const { name, description, price, category, isNew, isSoldOut, colors, sizes } = Astro.props;
---

<div
  class:list={[
    "group angular-card relative flex h-full flex-col overflow-hidden transition-all duration-300",
    isSoldOut
      ? "bg-[var(--surface-2)]/50 opacity-70 grayscale"
      : "bg-[var(--surface-2)] shadow-[0_0_20px_rgba(var(--brand-rgb),0.1)] hover:shadow-[0_0_30px_rgba(255,0,170,0.15)]",
  ]}
>
  <!-- Badges -->
  <div class="absolute top-0 left-0 z-10 flex flex-col gap-2 p-0">
    {
      isNew && !isSoldOut && (
        <span
          class="bg-[var(--cyber-yellow)] px-3 py-1 text-xs font-bold tracking-wider text-[var(--surface)] uppercase shadow-lg"
          style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 8px));"
        >
          NEW ARRIVAL
        </span>
      )
    }
    {
      isSoldOut && (
        <span
          class="bg-[var(--surface-3)] px-3 py-1 text-xs font-bold tracking-wider text-[var(--text-muted)] uppercase"
          style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 8px));"
        >
          SOLD OUT
        </span>
      )
    }
  </div>

  <!-- Image -->
  <div class="relative aspect-square overflow-hidden bg-gradient-to-br from-[var(--surface-3)] to-[var(--surface-2)]">
    <div class="flex h-full w-full items-center justify-center p-8">
      <!-- Placeholder icon since we don't have real images -->
      <svg
        class:list={[
          "h-24 w-24 transition-transform duration-500",
          !isSoldOut && "group-hover:scale-110 group-hover:rotate-3",
          isSoldOut ? "text-[var(--text-muted)]/30" : "text-[var(--brand)]",
        ]}
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        {
          category === "apparel" && (
            <path d="M21.6 18.2L13 11.75v-.91a3.496 3.496 0 00-.18-6.75A3.51 3.51 0 008.5 7.06h3c0-.85.58-1.56 1.36-1.77L12 7.06V7c0 .55.45 1 1 1s1-.45 1-1v-.06h0c.85 0 1.5.65 1.5 1.5s-.65 1.5-1.5 1.5h-4c-.55 0-1 .45-1 1s.45 1 1 1v.81l-8.6 6.45a2.5 2.5 0 003 4l5.1-3.83v4.07c0 .55.45 1 1 1s1-.45 1-1v-4.07l5.1 3.83a2.5 2.5 0 003-4z" />
          )
        }
        {
          category === "accessories" && (
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z" />
          )
        }
        {
          category === "stickers" && (
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.17.01-.34.02-.5l5.48 2.28v1.22c0 1.1.9 2 2 2h1v2.93zm6.78-5.58c-.29-.08-.59-.15-.78-.15h-2v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V5.08c3.39.49 6 3.4 6 6.92 0 .97-.19 1.9-.54 2.75l.32.6z" />
          )
        }
      </svg>
    </div>

    <!-- Decorative corner accent -->
    {
      !isSoldOut && (
        <div class="absolute right-0 bottom-0 h-1 w-12 bg-[var(--cyber-magenta)] transition-all duration-300 group-hover:w-full" />
      )
    }
  </div>

  <!-- Content -->
  <div class="flex flex-1 flex-col p-5">
    <!-- Category -->
    <div class="flex items-start justify-between">
      <span class="text-xs font-bold tracking-widest text-[var(--cyber-yellow)] uppercase">
        {category}
      </span>
      <div class="h-1 w-8 bg-[var(--border)] transition-colors group-hover:bg-[var(--brand)]"></div>
    </div>

    <!-- Name -->
    <h3 class="font-pixel mt-2 text-lg text-[var(--text)] transition-colors group-hover:text-[var(--cyber-magenta)]">
      {name}
    </h3>

    <!-- Description -->
    <p class="mt-2 line-clamp-2 font-mono text-sm text-[var(--text-muted)]">
      {description}
    </p>

    <!-- Options -->
    {
      colors && colors.length > 0 && (
        <div class="mt-3 flex items-center gap-2 font-mono text-xs text-[var(--text-muted)]">
          <span class="text-[var(--brand)]">></span>
          <span class="text-[var(--text)]">{colors.join(" / ")}</span>
        </div>
      )
    }
    {
      sizes && sizes.length > 0 && (
        <div class="mt-1 flex items-center gap-2 font-mono text-xs text-[var(--text-muted)]">
          <span class="text-[var(--brand)]">></span>
          <span class="text-[var(--text)]">{sizes.join(" / ")}</span>
        </div>
      )
    }

    <!-- Price & Action -->
    <div class="mt-auto flex items-center justify-between pt-6">
      <span class="font-pixel text-2xl text-[var(--brand)] transition-colors group-hover:text-[var(--cyber-yellow)]">
        ${price}
      </span>
      {
        !isSoldOut && (
          <button
            onclick={`window.dispatchEvent(new CustomEvent('open-merch-modal', { detail: { itemName: '${name}', price: ${price} } }))`}
            class="group relative inline-flex items-center gap-2 overflow-hidden bg-[var(--cyber-blue)] px-4 py-2 text-xs font-bold tracking-widest text-black uppercase transition-all hover:-translate-y-1 hover:bg-white hover:shadow-[0_0_15px_var(--cyber-blue)]"
            style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
          >
            <span class="relative z-10">Buy Now</span>
            <svg
              class="relative z-10 h-3 w-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"
              />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</div>
