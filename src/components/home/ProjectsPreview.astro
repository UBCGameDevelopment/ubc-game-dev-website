---
import { GameService } from "../../services";
import GlitchText from "../effects/GlitchText";
import BackgroundText from "../effects/BackgroundText.astro";

const featuredGames = GameService.getFeatured(3);
---

<section class="section-block relative z-10 overflow-hidden py-24">
  <div class="container-page relative z-10 mx-auto px-4">
    <div class="relative mb-12 flex items-end justify-between border-b border-[var(--border-dim)] pb-4">
      <BackgroundText
        text="PROJECTS"
        className="-top-12 -left-4 text-6xl opacity-[0.1] md:-top-20 md:text-8xl lg:text-[10rem]"
      />
      <h2 class="flex items-center gap-2 text-2xl font-bold tracking-wide text-white uppercase md:text-3xl">
        <span class="text-[var(--cyber-yellow)]">//</span>
        <GlitchText
          client:visible
          text="Selected_Works"
          tag="span"
        />
      </h2>
      <a
        href="/games"
        class="font-tech text-xs text-[var(--accent)] transition-colors hover:text-white"
      >
        VIEW_ALL_LOGS >>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredGames.map((game, index) => {
          let imageSrc = "/assets/placeholder-game.png";
          if (game.media && game.media.image) {
            imageSrc = game.media.image.src;
          } else if (game.media && game.media.images && game.media.images.length > 0) {
            imageSrc = game.media.images[0].src;
          }

          return (
            <a
              href={game.gameLink || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="group hud-card holo-effect cursor-pointer transition-transform hover:-translate-y-1 hover:border-[var(--cyber-blue)]"
              style={`animation-delay: ${index * 0.2}s`}
            >
              <div class="relative aspect-video overflow-hidden">
                <div
                  class="h-full w-full bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
                  style={`background-image: url('${imageSrc}'); filter: sepia(20%) hue-rotate(180deg) saturate(150%) contrast(1.2);`}
                >
                  <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-panel)] to-transparent opacity-80" />
                </div>
                <div class="absolute inset-0 bg-white/5 opacity-0 mix-blend-overlay transition-opacity group-hover:opacity-100" />
              </div>
              <div class="relative p-6">
                <div class="absolute top-0 left-0 h-[2px] w-full animate-pulse bg-[var(--cyber-blue)] opacity-0 group-hover:opacity-50" />

                <div class="mb-2 flex items-center justify-between">
                  <span class="font-tech text-base text-[var(--cyber-yellow)]">{game.year}</span>
                  {game.award && <span class="font-tech text-base text-[var(--text-muted)]">{game.award}</span>}
                </div>
                <h3 class="text-2xl font-bold text-white transition-colors group-hover:text-[var(--cyber-blue)]">
                  {game.name}
                </h3>
                <p class="mt-2 line-clamp-2 text-base text-[var(--text-muted)]">{game.description}</p>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .holo-effect {
    position: relative;
    overflow: hidden;
  }
  .holo-effect::after {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(to bottom, transparent 45%, rgba(0, 240, 255, 0.1) 50%, transparent 55%);
    background-size: 100% 8px;
    animation: holo-scan 6s linear infinite;
    pointer-events: none;
    z-index: 2;
    opacity: 0.3;
    mix-blend-mode: overlay;
  }

  @keyframes holo-scan {
    0% {
      transform: translateY(-10%) rotate(0deg);
    }
    100% {
      transform: translateY(10%) rotate(0deg);
    }
  }
</style>
