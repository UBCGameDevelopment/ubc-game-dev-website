---
export interface Props {
  title?: string;
  subtitle?: string;
  action?: string; // e.g., Formspree/Netlify URL
  method?: string; // "POST"
}
const {
  title = "SUBSCRIBE",
  subtitle = "Sign up for our newsletter to receive info about meetings, workshops, events and more!",
  action = "#",
  method = "POST",
} = Astro.props;
---

<section class="relative">
  <div class="container-page py-12 md:py-16">
    <h2 class="text-center text-3xl font-extrabold tracking-wide md:text-4xl">{title}</h2>
    <p class="mt-3 text-center text-sm text-gray-50/85 md:text-base">{subtitle}</p>

    <form
      action={action}
      method={method}
      class="mx-auto mt-8 grid max-w-3xl gap-5">
      <!-- Name -->
      <div>
        <label class="block font-semibold">Name <span class="opacity-70">(required)</span></label>
        <div class="mt-2 grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <span class="mb-1 block text-xs opacity-70">First Name</span>
            <input
              required
              name="first_name"
              type="text"
              class="focus-ring w-full rounded-xl border border-white/15 bg-white/[0.06] px-4 py-2"
              placeholder="Jane"
            />
          </div>
          <div>
            <span class="mb-1 block text-xs opacity-70">Last Name</span>
            <input
              required
              name="last_name"
              type="text"
              class="focus-ring w-full rounded-xl border border-white/15 bg-white/[0.06] px-4 py-2"
              placeholder="Doe"
            />
          </div>
        </div>
      </div>

      <!-- Email -->
      <div>
        <label class="block font-semibold">Email <span class="opacity-70">(required)</span></label>
        <input
          required
          name="email"
          type="email"
          class="focus-ring mt-2 w-full rounded-xl border border-white/15 bg-white/[0.06] px-4 py-2"
          placeholder="you@ubc.ca"
        />
      </div>

      <!-- Faculty -->
      <div>
        <label class="block font-semibold">Faculty <span class="opacity-70">(required)</span></label>
        <input
          required
          name="faculty"
          type="text"
          class="focus-ring mt-2 w-full rounded-xl border border-white/15 bg-white/[0.06] px-4 py-2"
          placeholder="Arts, Science, Applied Science, ..."
        />
      </div>

      <!-- Submit -->
      <div class="mt-2 text-center">
        <button
          type="submit"
          class="btn btn-outline rounded-full px-6 py-2 outline-[#E4E4E4]">
          Submit
        </button>
      </div>
    </form>

    <p class="mt-4 text-center text-xs text-gray-400">We only use your info for UBC Game Dev club communications.</p>
  </div>
</section>
