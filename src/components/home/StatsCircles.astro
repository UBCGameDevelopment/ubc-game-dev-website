---
export interface StatItem { value: string; labelTop?: string; labelBottom?: string; }
export interface Props { items: StatItem[]; }

const { items } = Astro.props;
---

<section class="my-12 md:my-16 container-page">
  <div class="gap-6 grid grid-cols-1 sm:grid-cols-3">
    {items.map((s) => (
      <div class="relative flex justify-center items-center bg-white/5 backdrop-blur-3xl mx-auto border border-white/30 rounded-full ring-1 ring-white/10 w-65 sm:w-52 md:w-60 aspect-square text-center"
      >
        <div class="space-y-4">
          <div class="font-bold text-6xl tracking-tight">{s.value}</div>
          <div class="opacity-90 text-2xl uppercase tracking-widest">{s.labelTop}</div>
          <div class="opacity-90 text-2xl uppercase tracking-widest">{s.labelBottom}</div>
        </div>

        <!-- soft highlight -->
        <span class="-top-1 -left-1 absolute bg-white/10 blur-2xl rounded-full w-20 h-20 pointer-events-none"></span>
      </div>
    ))}
  </div>
</section>

