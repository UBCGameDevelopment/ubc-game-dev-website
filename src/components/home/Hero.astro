---
import heroGraphic_0 from '../../assets/hero/hero-graphics-0.png';
import heroGraphic_1 from '../../assets/hero/hero-graphics-1.png';
---

<!-- NOTE: The number indicates the Z-index -->
<div class="relative mx-auto mt-16 mb-20 w-[1250px] max-w-full h-[700px]">
  <img src={heroGraphic_0.src} alt="Hero Graphic 0"
       class="z-0 absolute inset-0 w-full h-full object-contain" />
  <img src={heroGraphic_1.src} alt="Hero Graphic 1"
       class="z-10 absolute inset-0 m-auto h-auto" />
</div>