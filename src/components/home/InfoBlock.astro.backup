---
// src/components/InfoBlock.astro
export interface Props {
  title: string;
  imageSrc: string;
  imageAlt?: string;
  ctaHref?: string;
  ctaLabel?: string;
  reverse?: boolean; // put image on the right when true
}

const { title, imageSrc, imageAlt = "", ctaHref, ctaLabel, reverse = false } = Astro.props;
---

<section class="mx-auto my-10 max-w-5xl px-4 sm:px-6 md:my-14 lg:px-8">
  <div
    class="overflow-hidden rounded-3xl border border-[var(--border)] bg-[var(--surface-2)] p-4 shadow-xl transition-transform hover:-translate-y-1"
  >
    <div class={`grid md:grid-cols-2 items-center ${reverse ? "md:[&>*:first-child]:order-2" : ""}`}>
      <!-- Image -->
      <div class="p-5 md:p-7">
        <img
          src={imageSrc}
          alt={imageAlt}
          loading="lazy"
          class="h-full max-h-[420px] w-full rounded-2xl object-cover shadow-lg"
        />
      </div>

      <!-- Copy -->
      <div class="p-6 md:p-10">
        <h2 class="font-pixel mb-4 text-3xl tracking-wide text-[var(--text)] md:text-4xl">
          {title}
        </h2>

        <div class="space-y-4 text-[0.98rem] leading-relaxed text-[var(--text-muted)]">
          <slot />
        </div>

        {
          ctaHref && ctaLabel && (
            <div class="mt-6">
              <a
                href={ctaHref}
                class="inline-block rounded-xl bg-[var(--brand)] px-6 py-3 font-semibold text-white transition-all hover:bg-[var(--brand-hover)] hover:shadow-[var(--brand)]/20 hover:shadow-lg"
              >
                {ctaLabel}
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
