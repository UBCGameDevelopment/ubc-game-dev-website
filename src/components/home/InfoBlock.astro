---
// src/components/InfoBlock.astro
export interface Props {
  title: string;
  imageSrc: string;
  imageAlt?: string;
  ctaHref?: string;
  ctaLabel?: string;
  reverse?: boolean; // put image on the right when true
}

const {
  title,
  imageSrc,
  imageAlt = "",
  ctaHref,
  ctaLabel,
  reverse = false,
} = Astro.props;
---

<section class="my-10 md:my-14 container-page">
  <div
    class="bg-white/5 shadow-2xl shadow-black/40 backdrop-blur-2xl border border-white/20 rounded-3xl ring-1 ring-white/10 overflow-hidden"
  >
    <div class={`grid md:grid-cols-2 items-center ${reverse ? 'md:[&>*:first-child]:order-2' : ''}`}>
      <!-- Image -->
      <div class="p-5 md:p-7">
        <img
          src={imageSrc}
          alt={imageAlt}
          loading="lazy"
          class="shadow-lg rounded-2xl w-full h-full max-h-[420px] object-cover"
        />
      </div>

      <!-- Copy -->
      <div class="p-6 md:p-10">
        <h2 class="mb-4 font-extrabold text-3xl md:text-4xl tracking-wide">{title}</h2>

        <div class="space-y-4 text-[0.98rem] text-gray-50/90 leading-relaxed">
          <slot />
        </div>

        {ctaHref && ctaLabel && (
          <div class="mt-6">
            <a
              href={ctaHref}
              class="px-5 py-2 rounded-full btn-outline btn"
            >
              {ctaLabel}
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
