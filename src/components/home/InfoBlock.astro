---
// src/components/InfoBlock.astro
export interface Props {
  title: string;
  imageSrc: string;
  imageAlt?: string;
  ctaHref?: string;
  ctaLabel?: string;
  reverse?: boolean; // put image on the right when true
}

const { title, imageSrc, imageAlt = "", ctaHref, ctaLabel, reverse = false } = Astro.props;
---

<section class="mx-auto my-10 max-w-5xl px-4 sm:px-6 md:my-14 lg:px-8">
  <div
    class="overflow-hidden rounded-3xl border border-white/20 bg-white/5 p-4 shadow-2xl ring-1 shadow-black/40 ring-white/10 backdrop-blur-2xl">
    <div class={`grid md:grid-cols-2 items-center ${reverse ? "md:[&>*:first-child]:order-2" : ""}`}>
      <!-- Image -->
      <div class="p-5 md:p-7">
        <img
          src={imageSrc}
          alt={imageAlt}
          loading="lazy"
          class="h-full max-h-[420px] w-full rounded-2xl object-cover shadow-lg"
        />
      </div>

      <!-- Copy -->
      <div class="p-6 md:p-10">
        <h2 class="mb-4 text-3xl font-extrabold tracking-wide md:text-4xl">
          {title}
        </h2>

        <div class="space-y-4 text-[0.98rem] leading-relaxed text-gray-50/90">
          <slot />
        </div>

        {
          ctaHref && ctaLabel && (
            <div class="mt-6">
              <a
                href={ctaHref}
                class="btn-outline btn rounded-full border border-white/30 px-5 py-2">
                {ctaLabel}
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
