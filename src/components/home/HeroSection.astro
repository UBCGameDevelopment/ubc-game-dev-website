---
import CyberMarquee from "../effects/CyberMarquee.astro";
import GlitchText from "../effects/GlitchText";
---

<section class="section-block relative flex h-screen min-h-[800px] flex-col items-center justify-center p-4">
  <!-- Background Marquees -->
  <div class="pointer-events-none absolute inset-0 z-0 flex flex-col justify-between overflow-hidden py-32 select-none">
    <CyberMarquee
      text="UBC GAME DEV /// EST. 2017 /// VANCOUVER"
      speed={50}
      opacity="0.02"
      color="var(--text-muted)"
    />
    <CyberMarquee
      text="BUILD /// BREAK /// DEPLOY ///"
      direction="right"
      speed={40}
      opacity="0.02"
      color="var(--text-muted)"
    />
  </div>

  <!-- Center HUD -->
  <div class="relative z-20 text-center">
    <div class="mb-6 animate-pulse">
      <span
        class="border border-[var(--cyber-blue)] bg-[var(--cyber-blue)]/10 px-4 py-1 text-xs font-bold tracking-[0.2em] text-[var(--cyber-blue)] uppercase"
      >
        System Online
      </span>
    </div>

    <GlitchText
      client:visible
      tag="h1"
      text="UBC GAME DEV"
      className="mb-4 cursor-default text-6xl font-black tracking-tighter text-white uppercase md:text-8xl lg:text-9xl"
      options={{ speed: 70 }}
    />

    <p class="mx-auto max-w-xl text-lg font-medium tracking-widest text-[var(--text-muted)] uppercase md:text-xl">
      Build. <span class="text-[var(--cyber-yellow)]">Break.</span> Deploy.
    </p>

    <div class="mt-12 flex flex-col items-center gap-6 sm:flex-row sm:justify-center">
      <a
        href="/games"
        class="clip-angled relative overflow-hidden bg-[var(--brand)] px-8 py-4 font-bold tracking-widest text-white uppercase transition-all hover:bg-[var(--accent)] hover:shadow-[0_0_30px_var(--accent)]"
      >
        <span class="relative z-10">Initialize / Projects</span>
      </a>

      <a
        href="/about"
        class="group relative flex items-center gap-2 text-sm font-bold tracking-widest text-[var(--text-muted)] uppercase transition-colors hover:text-white"
      >
        <span>System Info</span>
        <span class="block h-1 w-1 bg-[var(--cyber-yellow)] transition-transform group-hover:scale-150"></span>
      </a>
    </div>
  </div>

  <!-- Bottom HUD Data -->
  <div class="font-tech absolute bottom-8 left-8 hidden text-xs text-[var(--border-dim)] md:block">
    <p>CORD: 49.2606° N, 123.2460° W</p>
    <p>LOC: VANCOUVER_GRID_04</p>
  </div>

  <div class="font-tech absolute right-8 bottom-8 hidden text-xs text-[var(--border-dim)] md:block">
    <p>STATUS: OPTIMAL</p>
    <p>VER: 2.0.77</p>
  </div>
</section>
