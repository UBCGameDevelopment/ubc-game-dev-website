---
import astroLogo from '../assets/astro.svg';
---

<footer class="bg-gray-800 mt-12 text-gray-300">
    <div class="gap-15 grid md:grid-cols-3 mx-auto px-10 py-8 max-w-6xl">
        <!-- Column 1: About -->
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <img src={astroLogo.src} alt="Club Logo" class="w-8 h-8 object-contain" />
                <h2 class="font-bold text-white text-lg">UBC Game Dev</h2>
            </div>
            <p class="opacity-80 text-sm">
                A student club for game development enthusiasts. We host events, workshops, and game jams.
            </p>
        </div>

        <!-- Column 2: Links -->
        <div>
            <h3 class="mb-2 font-semibold text-white">Quick Links</h3>
            <ul class="space-y-1 text-sm">
                <li><a href="/" class="hover:underline">Home</a></li>
                <li><a href="/about" class="hover:underline">About</a></li>
                <li><a href="/events" class="hover:underline">Events</a></li>
                <li><a href="/contact" class="hover:underline">Contact</a></li>
            </ul>
        </div>

        <!-- Column 3: Social -->
        <div class="justify-self-end">
            <h3 class="mb-2 font-semibold text-white">Our Socials</h3>
            <div class="flex space-x-4">
