---
// src/components/about/ExecGrid.astro
import ExecCard from "./ExecCard.astro";
import type { Exec } from "../../types";

export interface Props {
  execs: Exec[];
}

const { execs } = Astro.props;

// Find a single President; keep the rest in original order
const presidentIndex = execs.findIndex((e) => e.role === "President");
const president = presidentIndex >= 0 ? execs[presidentIndex] : null;
const rest = execs.filter((_, i) => i !== presidentIndex);

import PixelBadge from "../common/PixelBadge.astro";
---

<section class="container-page relative my-16 overflow-hidden md:my-20">
  <!-- Ambient Glow -->
  <div class="pointer-events-none absolute inset-0 z-0 flex items-start justify-center pt-20">
    <div
      class="h-[400px] w-[400px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_70%)] opacity-[0.08]"
    >
    </div>
  </div>

  <!-- Section Header -->
  <div class="relative z-10 mx-auto mb-12 max-w-3xl text-center">
    <div class="mb-4 inline-flex justify-center">
      <PixelBadge
        label="Meet The Team"
        variant="brand"
      />
    </div>

    <h2 class="font-pixel text-3xl font-extrabold tracking-tight text-[var(--text)] md:text-5xl">Our Executive Team</h2>
    <p class="mt-4 text-lg leading-relaxed text-[var(--text-muted)]">
      Meet the folks who keep UBC Game Dev running—events, workshops, and community!
    </p>
  </div>

  <!-- President row with special styling -->
  {
    president && (
      <div class="mt-12 flex justify-center">
        <div class="group relative">
          {/* Glow effect for president */}
          <div class="from-brand-500 to-accent-500 absolute -inset-4 rounded-full bg-gradient-to-r opacity-20 blur-2xl transition-opacity group-hover:opacity-30" />
          <div class="relative w-[200px] md:w-[220px]">
            <ExecCard {...president} />
          </div>
        </div>
      </div>
    )
  }

  <!-- Rest of execs in a modern grid -->
  <div class="mx-auto mt-16 grid max-w-6xl grid-cols-2 gap-8 md:grid-cols-3 md:gap-10 lg:grid-cols-4">
    {
      rest.map((e) => (
        <div class="flex justify-center">
          <div class="w-full max-w-[180px] md:max-w-[200px]">
            <ExecCard {...e} />
          </div>
        </div>
      ))
    }
  </div>
</section>
