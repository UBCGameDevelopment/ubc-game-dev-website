---
import { Image } from "astro:assets";
import type { Exec } from "../../types";

export interface Props extends Exec {}

const { name, role, linkedin, github, portfolio, image } = Astro.props;
---

<div class="group flex flex-col items-center text-center">
  <!-- Photo with hover effect -->
  <div class="relative">
    <!-- Glow effect on hover -->
    <div
      class="from-brand-500 to-accent-500 absolute -inset-2 rounded-full bg-gradient-to-r opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-50">
    </div>

    <div class="relative">
      <Image
        src={image}
        alt={`${name} headshot`}
        width={512}
        height={512}
        quality={99}
        format="webp"
        class="group-hover:ring-brand-400/60 group-hover:shadow-brand-500/20 h-32 w-32 rounded-full object-cover shadow-xl ring-2 ring-white/20 transition-all duration-300 group-hover:scale-105 group-hover:shadow-2xl md:h-36 md:w-36"
        loading="lazy"
      />

      {/* LinkedIn badge overlay */}
      <div
        class="from-brand-500 to-brand-700 absolute -right-2 -bottom-2 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br opacity-0 ring-2 ring-black/50 transition-opacity duration-300 group-hover:opacity-100">
        <a
          href={linkedin}
          target="_blank"
          rel="noreferrer noopener"
          class="flex h-full w-full items-center justify-center"
          aria-label={`LinkedIn profile for ${name}`}
          title="LinkedIn">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="white"
            class="h-5 w-5">
            <path
              d="M20.45 20.45h-3.55v-5.58c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.62-1.85 3.34-1.85 3.57 0 4.23 2.35 4.23 5.4v6.34zM5.34 7.44a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z">
            </path>
          </svg>
        </a>
      </div>

      {/* GitHub badge overlay */}
      {
        github && (
          <div class="absolute -bottom-2 -left-2 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-gray-800 to-gray-900 opacity-0 ring-2 ring-black/50 transition-opacity duration-300 group-hover:opacity-100">
            <a
              href={github}
              target="_blank"
              rel="noreferrer noopener"
              class="flex h-full w-full items-center justify-center"
              aria-label={`GitHub profile for ${name}`}
              title="GitHub">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="white"
                class="h-5 w-5">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.54.5.09.68-.22.68-.49 0-.24-.01-1.05-.01-1.9-2.78.6-3.37-1.34-3.37-1.34-.45-1.14-1.1-1.44-1.1-1.44-.9-.61.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.64.35-1.08.64-1.33-2.22-.25-4.56-1.11-4.56-4.93 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.57 9.57 0 0112 4.5c.84 0 1.68.11 2.47.32 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.82-2.34 4.68-4.56 4.93.36.31.68.92.68 1.85 0 1.34-.01 2.43-.01 2.77 0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z" />
              </svg>
            </a>
          </div>
        )
      }

      {/* Portfolio links */}
      {
        portfolio && (
          <div class="from-accent-500 to-accent-700 absolute -top-2 -right-2 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br opacity-0 ring-2 ring-black/50 transition-opacity duration-300 group-hover:opacity-100">
            <a
              href={portfolio}
              target="_blank"
              rel="noreferrer noopener"
              class="flex h-full w-full items-center justify-center"
              aria-label={`Portfolio website for ${name}`}
              title="Portfolio">
              {name === "Chloe Cheng" ? (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="white"
                  class="h-5 w-5">
                  <path d="M21 11c0-.55-.45-1-1-1h-.17l-2.57-2.57c.1-.32.17-.66.17-1.01 0-1.93-1.57-3.5-3.5-3.5-.96 0-1.83.38-2.47 1h-.92c-.64-.62-1.51-1-2.47-1C6.14 2.92 4.57 4.49 4.57 6.42c0 .35.07.69.17 1.01L2.17 10H2c-.55 0-1 .45-1 1v2c0 .55.45 1 1 1h1v5c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-5h1c.55 0 1-.45 1-1v-2zM8.07 4.92c.63 0 1.15.52 1.15 1.15s-.52 1.15-1.15 1.15-1.15-.52-1.15-1.15.52-1.15 1.15-1.15zm5.85 0c.63 0 1.15.52 1.15 1.15s-.52 1.15-1.15 1.15-1.15-.52-1.15-1.15.52-1.15 1.15-1.15zM19 19H5v-4h14v4z" />
                  <circle
                    cx="8"
                    cy="17"
                    r="1"
                  />
                  <circle
                    cx="12"
                    cy="17"
                    r="1"
                  />
                  <circle
                    cx="16"
                    cy="17"
                    r="1"
                  />
                </svg>
              ) : (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="white"
                  class="h-5 w-5">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM4 12c0-.61.08-1.21.21-1.78L8.99 15v1c0 1.1.9 2 2 2v1.93C7.06 19.43 4 16.07 4 12zm13.89 5.4c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41C17.92 5.77 20 8.65 20 12c0 2.08-.81 3.98-2.11 5.4z" />
                </svg>
              )}
            </a>
          </div>
        )
      }
    </div>
  </div>

  <!-- Name / Role -->
  <div class="mt-5">
    <div
      class="group-hover:text-brand-400 text-lg font-extrabold tracking-wide transition-colors duration-300 md:text-xl">
      {name}
    </div>
    <div class="mt-1 text-sm font-medium text-gray-300 md:text-base">{role}</div>
  </div>
</div>
