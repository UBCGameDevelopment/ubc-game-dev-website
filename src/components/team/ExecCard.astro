---
import { Image } from "astro:assets";
import type { Exec } from "../../types";
import LinkedInIcon from "../common/Icons/LinkedInIcon.astro";
import GitHubIcon from "../common/Icons/GitHubIcon.astro";
import PortfolioIcon from "../common/Icons/PortfolioIcon.astro";

export interface Props extends Exec {}

const { name, role, linkedin, github, portfolio, image } = Astro.props;
---

<div class="group flex flex-col items-center text-center">
  <div class="relative">
    <div
      class="from-brand-500 to-accent-500 absolute -inset-2 rounded-full bg-gradient-to-r opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-50"
    >
    </div>

    <div class="relative">
      <Image
        src={image}
        alt={`${name} headshot`}
        width={512}
        height={512}
        quality={99}
        format="webp"
        class="h-32 w-32 rounded-full object-cover shadow-xl ring-2 ring-[var(--border)] transition-all duration-300 group-hover:scale-105 group-hover:shadow-[var(--brand)]/20 group-hover:shadow-2xl group-hover:ring-[var(--brand)]/60 md:h-36 md:w-36"
        loading="lazy"
      />

      {/* LinkedIn badge overlay */}
      <div
        class="absolute -right-2 -bottom-2 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--brand)] opacity-0 ring-2 ring-[var(--surface-2)] transition-opacity duration-300 group-hover:opacity-100"
      >
        <a
          href={linkedin}
          target="_blank"
          rel="noreferrer noopener"
          class="flex h-full w-full items-center justify-center text-white"
          aria-label={`LinkedIn profile for ${name}`}
          title="LinkedIn"
        >
          <LinkedInIcon />
        </a>
      </div>

      {/* GitHub badge overlay */}
      {
        github && (
          <div class="absolute -bottom-2 -left-2 flex h-10 w-10 items-center justify-center rounded-full bg-gray-900 opacity-0 ring-2 ring-[var(--surface-2)] transition-opacity duration-300 group-hover:opacity-100">
            <a
              href={github}
              target="_blank"
              rel="noreferrer noopener"
              class="flex h-full w-full items-center justify-center text-white"
              aria-label={`GitHub profile for ${name}`}
              title="GitHub"
            >
              <GitHubIcon />
            </a>
          </div>
        )
      }

      {/* Portfolio links */}
      {
        portfolio && (
          <div class="absolute -top-2 -right-2 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--accent)] opacity-0 ring-2 ring-[var(--surface-2)] transition-opacity duration-300 group-hover:opacity-100">
            <a
              href={portfolio}
              target="_blank"
              rel="noreferrer noopener"
              class="flex h-full w-full items-center justify-center text-white"
              aria-label={`Portfolio website for ${name}`}
              title="Portfolio"
            >
              <PortfolioIcon variant={name === "Chloe Cheng" ? "robot" : "default"} />
            </a>
          </div>
        )
      }
    </div>
  </div>

  <div class="mt-5">
    <div
      class="text-lg font-extrabold tracking-wide text-[var(--text)] transition-colors duration-300 group-hover:text-[var(--brand)] md:text-xl"
    >
      {name}
    </div>
    <div class="mt-1 text-sm font-medium text-[var(--text-muted)] md:text-base">{role}</div>
  </div>
</div>
