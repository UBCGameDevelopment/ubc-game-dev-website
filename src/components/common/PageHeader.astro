---
import BackgroundText from "../effects/BackgroundText.astro";
import CyberBadge from "./CyberBadge.astro";

interface Props {
  backgroundText: string;
  badge: {
    label: string;
    variant: "brand" | "accent" | "yellow" | "magenta" | "blue";
  };
  subtitle: string;
  subtitleColor?: string; // e.g. "text-[var(--text-muted)]"
  title: {
    normal: string;
    highlight: string;
  };
  gradientClass: string; // e.g. "from-[var(--brand)] to-[var(--cyber-yellow)]"
  description: string;
  descriptionBorderColor?: string; // e.g. "border-[var(--brand)]"
  glowColor?: string; // e.g. "var(--brand)" - used for ambient glow
}

const {
  backgroundText,
  badge,
  subtitle,
  subtitleColor = "text-[var(--text-muted)]",
  title,
  gradientClass,
  description,
  descriptionBorderColor = "border-[var(--brand)]",
  glowColor = "var(--brand)",
} = Astro.props;
---

<section class="relative overflow-hidden pt-36 pb-16 md:pb-24">
  <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center">
    <div
      class="h-[600px] w-[600px] rounded-full opacity-[0.1]"
      style={`background: radial-gradient(circle, ${glowColor} 0%, transparent 50%);`}
    >
    </div>
    <div
      class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full opacity-[0.05]"
      style={`background: radial-gradient(circle, ${glowColor} 0%, transparent 60%);`}
    >
    </div>

    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(var(--brand-rgb),0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(var(--brand-rgb),0.03)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_70%)] bg-[size:4rem_4rem]"
    >
    </div>
  </div>

  <div class="container-page relative z-10 mx-auto px-4 text-center">
    <BackgroundText
      text={backgroundText}
      className="top-0 left-1/2 -translate-x-1/2 text-9xl font-black tracking-tighter opacity-[0.04] md:text-[13rem]"
    />

    <div class="mb-6 inline-flex justify-center">
      <CyberBadge
        label={badge.label}
        variant={badge.variant}
      />
    </div>

    <h1 class="mb-6 flex flex-col items-center justify-center gap-2 md:gap-4">
      <span class:list={["font-tech text-sm font-bold tracking-[0.5em] uppercase md:text-base", subtitleColor]}>
        {subtitle}
      </span>
      <span class="font-display text-5xl font-black tracking-tight text-white uppercase md:text-7xl lg:text-8xl">
        {title.normal}
        <span
          class:list={[
            "bg-gradient-to-r bg-clip-text text-transparent drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] filter",
            gradientClass,
          ]}
        >
          {title.highlight}
        </span>
      </span>
    </h1>

    <p
      class:list={[
        "mx-auto mt-6 max-w-2xl border-l-2 pl-6 text-left text-lg leading-relaxed text-[var(--text-muted)] md:border-l-0 md:pl-0 md:text-center",
        descriptionBorderColor,
      ]}
    >
      {description}
    </p>

    <slot />
  </div>
</section>
