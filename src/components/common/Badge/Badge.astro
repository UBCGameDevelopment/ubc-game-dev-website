---
interface Props {
    label: string;
    variant?: "event" | "game" | "default";
    class?: string;
}

const { label, variant = "default", class: className = "" } = Astro.props;

const variantClasses = {
    event: "border-brand-500/30 bg-brand-500/20",
    game: "border-brand-500/30 bg-brand-500/20",
    default: "border-white/30 bg-white/20",
};

const textColorClasses = {
    event: "text-brand-400",
    game: "text-brand-400",
    default: "text-white",
};
---

<div
    class={`inline-flex w-fit items-center gap-2 rounded-full border px-2.5 py-0.5 ${variantClasses[variant]} ${className}`}>
    <span class={`text-xs font-semibold tracking-wide uppercase ${textColorClasses[variant]}`}>
        {label}
    </span>
</div>
