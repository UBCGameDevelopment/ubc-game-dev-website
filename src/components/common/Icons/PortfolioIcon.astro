---
export interface Props {
  class?: string;
  variant?: 'default' | 'robot';
}

const { class: className = "h-5 w-5", variant = 'default' } = Astro.props;
---

{variant === 'robot' ? (
  <!-- Robot icon for special portfolio links -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="white"
    class={className}
    aria-hidden="true">
    <path
      d="M21 11c0-.55-.45-1-1-1h-.17l-2.57-2.57c.1-.32.17-.66.17-1.01 0-1.93-1.57-3.5-3.5-3.5-.96 0-1.83.38-2.47 1h-.92c-.64-.62-1.51-1-2.47-1C6.14 2.92 4.57 4.49 4.57 6.42c0 .35.07.69.17 1.01L2.17 10H2c-.55 0-1 .45-1 1v2c0 .55.45 1 1 1h1v5c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-5h1c.55 0 1-.45 1-1v-2zM8.07 4.92c.63 0 1.15.52 1.15 1.15s-.52 1.15-1.15 1.15-1.15-.52-1.15-1.15.52-1.15 1.15-1.15zm5.85 0c.63 0 1.15.52 1.15 1.15s-.52 1.15-1.15 1.15-1.15-.52-1.15-1.15.52-1.15 1.15-1.15zM19 19H5v-4h14v4z">
    </path>
    <circle cx="8" cy="17" r="1"></circle>
    <circle cx="12" cy="17" r="1"></circle>
    <circle cx="16" cy="17" r="1"></circle>
  </svg>
) : (
  <!-- Default globe/portfolio icon -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="white"
    class={className}
    aria-hidden="true">
    <path
      d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z">
    </path>
  </svg>
)}
