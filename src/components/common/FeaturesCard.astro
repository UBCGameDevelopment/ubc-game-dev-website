---
export interface Props {
  title: string;
  children?: any; // description goes in slot
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  cta?: string;
}

const { title, imageSrc, imageAlt = "", href, cta = "Learn More" } = Astro.props;
---

<article
  class="flex h-full flex-col gap-5 rounded-3xl border border-[var(--border)] bg-[var(--surface-2)] p-6 shadow-xl transition-transform hover:-translate-y-1 md:min-h-96 md:p-8"
>
  <!-- Title -->
  <h5 class="font-pixel my-4 text-5xl tracking-wide text-[var(--text)]">{title}</h5>

  <div class="text-lg leading-relaxed text-[var(--text-muted)]">
    <slot />
  </div>

  {
    imageSrc && (
      <img
        src={imageSrc}
        alt={imageAlt}
        loading="lazy"
        class="max-h-60 rounded-xl border border-[var(--border)] object-cover"
      />
    )
  }

  {
    href && (
      <div class="mt-2">
        <a
          href={href}
          class="inline-block rounded-xl bg-[var(--brand)] px-6 py-3 font-semibold text-white transition-all hover:bg-[var(--brand-hover)] hover:shadow-[var(--brand)]/20 hover:shadow-lg"
        >
          {cta}
        </a>
      </div>
    )
  }
</article>
