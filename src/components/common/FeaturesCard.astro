---
export interface Props {
  title: string;
  children?: any;     // description goes in slot
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  cta?: string;
}

const { title, imageSrc, imageAlt = "", href, cta = "Learn More" } = Astro.props;
---

<article
  class="flex flex-col gap-5 bg-white/5 shadow-2xl shadow-black/50 backdrop-blur-3xl p-6 md:p-8 border border-white/30 rounded-3xl"
>
  <h3 class="font-extrabold text-2xl tracking-wide">{title}</h3>

  <div class="text-[0.98rem] text-gray-50/85 leading-relaxed">
    <slot />
  </div>

  {imageSrc && (
    <img
      src={imageSrc}
      alt={imageAlt}
      loading="lazy"
      class="border border-white/10 rounded-xl max-h-36 object-cover"
    />
  )}

  {href && (
    <div class="mt-2">
      <a href={href} class="px-5 py-2 rounded-full btn-outline btn">
        {cta}
      </a>
    </div>
  )}
</article>
