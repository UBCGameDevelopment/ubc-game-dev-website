---
interface Props {
  label: string;
  variant?: "brand" | "accent" | "yellow" | "magenta";
  class?: string;
  icon?: string; // Optional icon slot or name
}

const { label, variant = "brand", class: className } = Astro.props;

const variants = {
  brand: {
    bg: "bg-[var(--brand)]",
    text: "text-white",
    border: "border-transparent",
    shadow: "shadow-[0_0_15px_var(--brand)]",
  },
  accent: {
    bg: "bg-[var(--accent)]",
    text: "text-[var(--surface)]",
    border: "border-transparent",
    shadow: "shadow-[0_0_15px_var(--accent)]",
  },
  yellow: {
    bg: "bg-[var(--cyber-yellow)]",
    text: "text-[var(--surface)]",
    border: "border-transparent",
    shadow: "shadow-[0_0_15px_var(--cyber-yellow)]",
  },
  magenta: {
    bg: "bg-[var(--cyber-magenta)]",
    text: "text-white",
    border: "border-transparent",
    shadow: "shadow-[0_0_15px_var(--cyber-magenta)]",
  },
};

const style = variants[variant] || variants.brand;
---

<div
  class:list={[
    "clip-angled inline-flex items-center gap-2 px-4 py-1.5 font-bold tracking-widest uppercase transition-transform hover:-translate-y-0.5",
    style.bg,
    style.text,
    style.shadow,
    className,
  ]}
>
  <slot name="icon" />
  <span class="font-tech text-xs tracking-[0.15em]">
    {label}
  </span>
</div>
