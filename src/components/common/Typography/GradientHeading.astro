---
export interface Props {
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  class?: string;
  pixel?: boolean;
}

const { as: Tag = "h2", class: className = "", pixel = false } = Astro.props;
const fontClass = pixel ? "font-pixel" : "";
---

<Tag class={`font-extrabold tracking-tight text-[var(--text)] ${fontClass} ${className}`}>
  <slot />
</Tag>
