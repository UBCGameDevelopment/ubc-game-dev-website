---
export interface Props {
    as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
    class?: string;
}

const { as: Tag = "h2", class: className = "" } = Astro.props;
---

<Tag
    class={`bg-gradient-to-r from-white via-gray-100 to-gray-300 bg-clip-text font-extrabold tracking-tight text-transparent ${className}`}>
    <slot />
</Tag>
