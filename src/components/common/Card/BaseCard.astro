---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<article class={`group relative ${className}`}>
  <!-- Main card container -->
  <div
    class="relative overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface-2)] shadow-md transition-all duration-300 hover:-translate-y-1 hover:border-[var(--brand)] hover:shadow-lg"
  >
    <div class="relative z-10">
      <slot />
    </div>
  </div>
</article>
