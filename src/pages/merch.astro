---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton";
import MerchCard from "../components/merch/MerchCard.astro";
import { merchItems, categories } from "../data/merch";
import { LINKS } from "../config/links";
import PixelBadge from "../components/common/PixelBadge.astro";
import MerchPurchaseModal from "../components/merch/MerchPurchaseModal.tsx";
---

<Layout>
  <MerchPurchaseModal client:load />
  <main>
    <!-- Header Section -->
    <section class="relative overflow-hidden pt-32 pb-16 md:pb-24">
      <!-- Enhanced Ambient Glow - Space Vibes -->
      <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center">
        <div
          class="h-[550px] w-[550px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_50%)] opacity-[0.15]"
        >
        </div>
        <div
          class="absolute -left-24 h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,var(--accent)_0%,transparent_70%)] opacity-[0.12]"
        >
        </div>
        <div
          class="absolute -right-24 h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,var(--cyber-magenta)_0%,transparent_70%)] opacity-[0.08]"
        >
        </div>
      </div>

      <!-- Floating Particles -->
      <div class="pointer-events-none absolute inset-0 z-5 overflow-hidden">
        <div
          class="float-anim absolute top-[25%] left-[12%] h-1.5 w-1.5 rotate-45 bg-[var(--brand)] opacity-35"
          style="animation-delay: 0.3s;"
        >
        </div>
        <div
          class="float-anim absolute top-[35%] right-[15%] h-2 w-2 rotate-45 bg-[var(--accent)] opacity-25"
          style="animation-delay: 1s;"
        >
        </div>
        <div
          class="float-anim absolute top-[65%] right-[8%] h-1 w-1 rounded-full bg-[var(--cyber-magenta)] opacity-45"
          style="animation-delay: 1.8s;"
        >
        </div>
      </div>

      <div class="container-page relative z-10 mx-auto px-4 text-center">
        <div class="mb-4 inline-flex justify-center">
          <PixelBadge
            label="Shop"
            variant="brand"
          />
        </div>

        <h1
          class="font-pixel text-4xl font-extrabold tracking-tight text-[var(--text)] uppercase md:text-5xl lg:text-6xl"
        >
          Merch <span class="text-[var(--cyber-yellow)]">Store</span>
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--text-muted)]">
          Rep UBC Game Dev with our exclusive merch! All proceeds support club events, workshops, and events.
        </p>

        <!-- Category Filter - Angular Style -->
        <div class="mx-auto mt-12 flex flex-wrap justify-center gap-4">
          <button
            data-category="all"
            class="filter-btn active font-pixel px-6 py-2 text-sm tracking-wider uppercase transition-all duration-200"
            style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
          >
            All Items
          </button>

          {
            categories
              .filter((c) => c.id !== "all")
              .map((cat) => (
                <button
                  data-category={cat.id}
                  class="filter-btn font-pixel bg-[var(--surface-2)] px-6 py-2 text-sm tracking-wider text-[var(--text-muted)] uppercase transition-all duration-200 hover:bg-[var(--surface-3)] hover:text-white"
                  style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
                >
                  {cat.label}
                </button>
              ))
          }
        </div>
      </div>
    </section>

    <!-- Hex Divider -->
    <div class="hex-divider mx-auto mb-16 max-w-4xl opacity-50"></div>

    <style>
      .filter-btn.active {
        background-color: var(--cyber-yellow);
        color: var(--surface);
        font-weight: bold;
        box-shadow: 0 0 15px rgba(252, 238, 10, 0.3);
      }
    </style>

    <!-- Product Grid -->
    <section class="container-page mx-auto px-4 pb-20">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          merchItems.map((item) => (
            <div
              data-merch-item
              data-item-category={item.category}
              class="h-full"
            >
              <MerchCard {...item} />
            </div>
          ))
        }
      </div>

      <!-- Empty State -->
      <div
        id="empty-state"
        class="hidden py-16 text-center"
      >
        <p class="font-pixel text-xl text-[var(--text-muted)]">No items in this category</p>
      </div>
    </section>

    <!-- Coming Soon Banner -->
    <section class="container-page mx-auto px-4 pb-20">
      <div
        class="rounded-3xl border border-[var(--brand)]/30 bg-gradient-to-br from-[var(--brand)]/10 to-[var(--accent)]/10 p-8 text-center md:p-12"
      >
        <h2 class="font-pixel text-2xl text-[var(--text)] md:text-3xl">More Coming Soon!</h2>
        <p class="mx-auto mt-3 max-w-xl text-[var(--text-muted)]">
          Join our Discord to get notified when new items drop and for exclusive member discounts.
        </p>
        <CtaButton
          client:load
          label="Join Discord"
          href={LINKS.discord}
          className="mt-6"
        />
      </div>
    </section>
  </main>
</Layout>

<script>
  // Category filter functionality
  const categoryButtons = document.querySelectorAll("[data-category]");
  const merchItems = document.querySelectorAll("[data-merch-item]");
  const emptyState = document.getElementById("empty-state");

  categoryButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const category = button.getAttribute("data-category");

      // Update button styles
      categoryButtons.forEach((btn) => {
        btn.classList.remove("active");
        btn.classList.add("bg-[var(--surface-2)]", "text-[var(--text-muted)]");
      });
      button.classList.remove("bg-[var(--surface-2)]", "text-[var(--text-muted)]");
      button.classList.add("active");

      // Filter items
      let visibleCount = 0;
      merchItems.forEach((item) => {
        const itemCategory = item.getAttribute("data-item-category");
        if (category === "all" || itemCategory === category) {
          (item as HTMLElement).style.display = "";
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = "none";
        }
      });

      // Show/hide empty state
      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    });
  });
</script>
