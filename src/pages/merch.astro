---
import Layout from "../layouts/Layout.astro";
import MerchHeader from "../components/merch/MerchHeader.astro";
import MerchSidebar from "../components/merch/MerchSidebar.astro";
import DropNotification from "../components/merch/DropNotification.astro";
import MerchCard from "../components/merch/MerchCard.astro";
import MerchPurchaseModal from "../components/merch/MerchPurchaseModal";
import { merchItems, categories } from "../data/merch";

const isPlaceholder = (src: string) => src.includes("/placeholder-") || src.includes("placeholder.");

const featuredItem = merchItems.find((item) => item.isNew && !item.isSoldOut) ?? merchItems[0];

const validFeaturedImages = (featuredItem?.images ?? []).filter((src) => !isPlaceholder(src));
const featuredImage = validFeaturedImages[0] ?? "";
---

<Layout
  title="UBC Game Dev // Loadout Terminal"
  immersive
>
  <MerchPurchaseModal client:load />
  <main>
    <MerchHeader />

    <section class="container-page mx-auto px-4 pb-24">
      <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
        <MerchSidebar categories={categories} />

        <div class="relative overflow-hidden border border-[var(--border-dim)] bg-[var(--bg-panel)]/70 backdrop-blur">
          <div
            class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.3)_50%),linear-gradient(90deg,rgba(0,240,255,0.05),rgba(255,0,170,0.03),rgba(0,0,0,0))] bg-[length:100%_2px,3px_100%] opacity-20"
          >
          </div>

          <div class="relative z-10 space-y-8 p-6 md:p-10">
            <div
              id="featured-header"
              class="flex items-center justify-between border-b border-[var(--border-dim)] pb-4"
            >
              <div>
                <p class="font-tech text-xs tracking-widest text-[var(--text-muted)] uppercase">Loadout Preview</p>
                <h2 class="text-2xl font-bold tracking-wide text-white uppercase md:text-3xl">Outfit Config</h2>
              </div>
              <span class="font-tech text-xs text-[var(--cyber-yellow)]">SYNC // OK</span>
            </div>

            <div
              id="featured-section"
              class="group relative overflow-hidden border border-[var(--border-dim)] bg-[var(--bg-deep)]/60 transition-all hover:border-[var(--cyber-blue)]"
            >
              <div class="flex flex-col md:flex-row">
                <div
                  class="relative aspect-square w-full shrink-0 overflow-hidden border-b border-[var(--border-dim)] md:w-[55%] md:border-r md:border-b-0"
                >
                  <div
                    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,240,255,0.1),transparent_70%)]"
                  >
                  </div>

                  <img
                    id="featured-preview-image"
                    src={featuredImage}
                    alt={featuredItem?.name ?? "Featured item"}
                    class:list={["absolute inset-0 h-full w-full object-contain", !featuredImage && "hidden"]}
                  />

                  <div
                    id="featured-preview-icon-container"
                    class:list={["absolute inset-0 flex items-center justify-center", featuredImage && "hidden"]}
                  >
                    <svg
                      data-preview-icon="apparel"
                      class:list={[
                        "h-32 w-32 text-[var(--cyber-blue)] drop-shadow-[0_0_18px_rgba(0,240,255,0.5)]",
                        featuredItem?.category !== "apparel" && "hidden",
                      ]}
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        d="M21.6 18.2L13 11.75v-.91a3.496 3.496 0 00-.18-6.75A3.51 3.51 0 008.5 7.06h3c0-.85.58-1.56 1.36-1.77L12 7.06V7c0 .55.45 1 1 1s1-.45 1-1v-.06h0c.85 0 1.5.65 1.5 1.5s-.65 1.5-1.5 1.5h-4c-.55 0-1 .45-1 1s.45 1 1 1v.81l-8.6 6.45a2.5 2.5 0 003 4l5.1-3.83v4.07c0 .55.45 1 1 1s1-.45 1-1v-4.07l5.1 3.83a2.5 2.5 0 003-4z"
                      >
                      </path>
                    </svg>
                    <svg
                      data-preview-icon="accessories"
                      class:list={[
                        "h-32 w-32 text-[var(--cyber-blue)] drop-shadow-[0_0_18px_rgba(0,240,255,0.5)]",
                        featuredItem?.category !== "accessories" && "hidden",
                      ]}
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5-9h10v2H7z"
                      >
                      </path>
                    </svg>
                    <svg
                      data-preview-icon="stickers"
                      class:list={[
                        "h-32 w-32 text-[var(--cyber-blue)] drop-shadow-[0_0_18px_rgba(0,240,255,0.5)]",
                        featuredItem?.category !== "stickers" && "hidden",
                      ]}
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.17.01-.34.02-.5l5.48 2.28v1.22c0 1.1.9 2 2 2h1v2.93zm6.78-5.58c-.29-.08-.59-.15-.78-.15h-2v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V5.08c3.39.49 6 3.4 6 6.92 0 .97-.19 1.9-.54 2.75l.32.6z"
                      >
                      </path>
                    </svg>
                  </div>

                  <div class="absolute top-4 left-4">
                    <span
                      class="font-tech bg-black/60 px-2 py-1 text-[10px] tracking-widest text-[var(--cyber-blue)] uppercase backdrop-blur-sm"
                    >
                      Preview Bay
                    </span>
                  </div>
                  <div class="absolute bottom-4 left-4">
                    <span class="font-tech block text-[10px] tracking-widest text-[var(--text-muted)] uppercase">
                      Featured Slot
                    </span>
                    <span
                      id="featured-preview-name"
                      class="block text-sm font-bold text-white drop-shadow-md"
                    >
                      {featuredItem?.name}
                    </span>
                  </div>
                </div>

                <div class="flex flex-1 flex-col p-6 md:p-8">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <span class="h-2 w-2 bg-[var(--cyber-magenta)] shadow-[0_0_12px_var(--cyber-magenta)]"></span>
                      <p class="font-tech text-xs tracking-widest text-[var(--cyber-magenta)] uppercase">
                        Featured Drop
                      </p>
                    </div>
                    <span
                      id="featured-new-badge"
                      class:list={[
                        "rounded-sm bg-[var(--cyber-yellow)] px-2 py-0.5 text-[10px] font-bold text-black",
                        !featuredItem?.isNew && "hidden",
                      ]}
                    >
                      NEW
                    </span>
                  </div>

                  <h3
                    id="featured-title"
                    class="font-tech mt-4 text-2xl font-bold text-white uppercase md:text-3xl"
                  >
                    {featuredItem?.name}
                  </h3>

                  <p
                    id="featured-description"
                    class="font-tech mt-4 line-clamp-4 text-base leading-relaxed text-[var(--text-muted)]"
                  >
                    {featuredItem?.description}
                  </p>

                  <div
                    class="font-tech mt-8 space-y-3 border-t border-[var(--border-dim)] pt-6 text-[10px] tracking-widest text-[var(--text-muted)] uppercase"
                  >
                    <div
                      data-featured-colors
                      class:list={[
                        "flex items-center justify-between",
                        (!featuredItem?.colors || featuredItem.colors.length === 0) && "hidden",
                      ]}
                    >
                      <span>Colors</span>
                      <span
                        id="featured-colors"
                        class="text-white"
                      >
                        {featuredItem?.colors?.join(" / ")}
                      </span>
                    </div>
                    <div
                      data-featured-sizes
                      class:list={[
                        "flex items-center justify-between",
                        (!featuredItem?.sizes || featuredItem.sizes.length === 0) && "hidden",
                      ]}
                    >
                      <span>Sizes</span>
                      <span
                        id="featured-sizes"
                        class="text-white"
                      >
                        {featuredItem?.sizes?.join(" / ")}
                      </span>
                    </div>
                    <div class="flex items-center justify-between">
                      <span>Category</span>
                      <span
                        id="featured-preview-category"
                        class="text-white"
                      >
                        {featuredItem?.category?.toUpperCase()}
                      </span>
                    </div>
                    <div class="flex items-center justify-between">
                      <span>Drop</span>
                      <span
                        id="featured-preview-drop"
                        class="text-[var(--cyber-yellow)]"
                      >
                        {featuredItem?.isNew ? "New" : "Standard"}
                      </span>
                    </div>
                  </div>

                  <div class="mt-auto flex items-center justify-between pt-8">
                    <span
                      id="featured-price"
                      class="font-pixel text-4xl text-[var(--cyber-yellow)]"
                    >
                      ${featuredItem?.price} CAD
                    </span>
                    <button
                      id="featured-cta"
                      data-item-name={featuredItem?.name ?? ""}
                      data-item-price={featuredItem?.price ?? 0}
                      data-item-json={JSON.stringify(featuredItem)}
                      class="clip-angled group relative inline-flex items-center gap-3 bg-[var(--cyber-blue)] px-6 py-3 text-xs font-bold tracking-widest text-black uppercase transition-all hover:-translate-y-1 hover:bg-white hover:shadow-[0_0_20px_var(--cyber-blue)]"
                    >
                      <span>Equip Note</span>
                      <svg
                        class="h-4 w-4 transition-transform group-hover:translate-x-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14 5l7 7m0 0l-7 7m7-7H3"
                        >
                        </path>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div
              id="inventory-divider"
              class="border-t border-[var(--border-dim)] pt-6"
            >
              <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                  <p class="font-tech text-xs tracking-widest text-[var(--text-muted)] uppercase">Inventory Feed</p>
                  <h3 class="text-2xl font-bold text-white uppercase">
                    Items // <span
                      id="active-category-label"
                      class="text-[var(--cyber-yellow)]"
                    >
                      All
                    </span>
                  </h3>
                </div>
                <div class="flex items-center gap-3 text-[10px] tracking-widest text-[var(--text-muted)] uppercase">
                  <span class="mr-1">Sort</span>
                  <button
                    id="sort-newest"
                    class="sort-btn active"
                  >
                    Newest
                  </button>
                  <button
                    id="sort-price"
                    class="sort-btn flex items-center gap-2"
                  >
                    Price
                    <span
                      id="sort-price-icon"
                      class="hidden text-xs"
                    >
                      ↑
                    </span>
                  </button>
                </div>
              </div>

              <div class="mt-6 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
                {
                  merchItems.map((item) => {
                    // Filter placeholders from this item's images
                    const itemValidImages = (item.images ?? []).filter((src) => !isPlaceholder(src));
                    const itemImage = itemValidImages[0] ?? "";

                    return (
                      <div
                        data-merch-item
                        data-item-category={item.category}
                        data-item-name={item.name}
                        data-item-description={item.description}
                        data-item-price={item.price}
                        data-item-image={itemImage}
                        data-item-colors={item.colors?.join(" / ") ?? ""}
                        data-item-sizes={item.sizes?.join(" / ") ?? ""}
                        data-item-is-new={item.isNew ? "true" : "false"}
                        data-featured-default={item.id === featuredItem?.id ? "true" : "false"}
                        data-item-json={JSON.stringify(item)}
                        class="h-full"
                      >
                        <MerchCard {...item} />
                      </div>
                    );
                  })
                }
              </div>

              <div
                id="empty-state"
                class="hidden py-16 text-center"
              >
                <p class="font-tech text-sm tracking-widest text-[var(--text-muted)] uppercase">
                  No gear in this category
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <DropNotification />
  </main>
</Layout>

<style>
  .loadout-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    border: 1px solid var(--border-dim);
    padding: 12px 16px 12px 20px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(5, 5, 8, 0.6);
    color: var(--text-muted);
    transition: all 0.2s ease;
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
  }

  .loadout-btn:hover {
    border-color: var(--brand);
    color: white;
    background: rgba(10, 10, 12, 0.8);
  }

  .loadout-btn-indicator {
    color: var(--cyber-yellow);
    opacity: 0.6;
  }

  .filter-btn.active {
    background: var(--cyber-yellow);
    color: #050505;
    border-color: var(--cyber-yellow);
    box-shadow: 0 0 15px rgba(252, 238, 10, 0.3);
  }

  .filter-btn.active .loadout-btn-indicator {
    color: #050505;
    opacity: 1;
  }

  .preview-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px solid rgba(120, 230, 255, 0.25);
    background:
      radial-gradient(circle at 50% 15%, rgba(120, 230, 255, 0.18), transparent 55%),
      linear-gradient(180deg, rgba(8, 16, 20, 0.2), rgba(0, 0, 0, 0.8));
    overflow: hidden;
  }

  .preview-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.06),
        rgba(255, 255, 255, 0.06) 1px,
        transparent 2px,
        transparent 5px
      ),
      radial-gradient(circle at 30% 30%, rgba(160, 240, 255, 0.18), transparent 45%);
    opacity: 0.35;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .preview-image-element {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .preview-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.8;
  }

  .preview-label {
    position: absolute;
    left: 16px;
    bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sort-btn {
    appearance: none;
    background: transparent;
    border: 1px solid var(--border-dim);
    color: var(--text-muted);
    padding: 6px 12px;
    font-family: var(--font-tech);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.2s ease;
    clip-path: polygon(4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%, 0 4px);
  }

  .sort-btn:hover {
    border-color: var(--cyber-blue);
    color: white;
    box-shadow: 0 0 10px rgba(0, 240, 255, 0.2);
  }

  .sort-btn.active {
    background: var(--cyber-blue);
    border-color: var(--cyber-blue);
    color: #000;
    box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
  }

  .sort-btn.active:hover {
    background: white;
    border-color: white;
    color: #000;
  }
</style>

<script>
  const dom = {
    categoryButtons: document.querySelectorAll("[data-category]"),
    merchItems: Array.from(document.querySelectorAll("[data-merch-item]")),
    emptyState: document.getElementById("empty-state"),
    activeLabel: document.getElementById("active-category-label"),
    featuredSection: document.getElementById("featured-section"),
    featuredHeader: document.getElementById("featured-header"),
    inventoryDivider: document.getElementById("inventory-divider"),
    previewIcons: document.querySelectorAll("[data-preview-icon]"),
    featured: {
      title: document.getElementById("featured-title"),
      description: document.getElementById("featured-description"),
      price: document.getElementById("featured-price"),
      colors: document.getElementById("featured-colors"),
      sizes: document.getElementById("featured-sizes"),
      colorsRow: document.querySelector("[data-featured-colors]"),
      sizesRow: document.querySelector("[data-featured-sizes]"),
      newBadge: document.getElementById("featured-new-badge"),
      cta: document.getElementById("featured-cta"),
      previewImage: document.getElementById("featured-preview-image"),
      previewIconContainer: document.getElementById("featured-preview-icon-container"),
      previewName: document.getElementById("featured-preview-name"),
      previewCategory: document.getElementById("featured-preview-category"),
      previewDrop: document.getElementById("featured-preview-drop"),
    },
    sort: {
      newest: document.getElementById("sort-newest"),
      price: document.getElementById("sort-price"),
      priceIcon: document.getElementById("sort-price-icon"),
    },
  };

  let currentSort: "newest" | "price-asc" | "price-desc" = "newest";

  const sortItems = () => {
    const container = dom.merchItems[0]?.parentElement;
    if (!container) return;

    const items = Array.from(dom.merchItems);

    items.sort((a, b) => {
      if (!(a instanceof HTMLElement) || !(b instanceof HTMLElement)) return 0;

      if (currentSort === "newest") {
        const aNew = a.dataset.itemIsNew === "true";
        const bNew = b.dataset.itemIsNew === "true";
        if (aNew && !bNew) return -1;
        if (!aNew && bNew) return 1;
        return 0;
      }

      const aPrice = parseFloat(a.dataset.itemPrice || "0");
      const bPrice = parseFloat(b.dataset.itemPrice || "0");

      if (currentSort === "price-asc") {
        return aPrice - bPrice;
      } else {
        return bPrice - aPrice;
      }
    });

    items.forEach((item) => container.appendChild(item));
  };

  const updateSortUI = () => {
    if (dom.sort.newest) {
      dom.sort.newest.classList.toggle("active", currentSort === "newest");
    }

    if (dom.sort.price) {
      const isPrice = currentSort.startsWith("price");
      dom.sort.price.classList.toggle("active", isPrice);

      if (dom.sort.priceIcon) {
        dom.sort.priceIcon.classList.toggle("hidden", !isPrice);
        dom.sort.priceIcon.textContent = currentSort === "price-asc" ? "↑" : "↓";
      }
    }
  };

  if (dom.sort.newest) {
    dom.sort.newest.addEventListener("click", () => {
      if (currentSort !== "newest") {
        currentSort = "newest";
        updateSortUI();
        sortItems();
      }
    });
  }

  if (dom.sort.price) {
    dom.sort.price.addEventListener("click", () => {
      if (currentSort === "price-asc") {
        currentSort = "price-desc";
      } else {
        currentSort = "price-asc";
      }
      updateSortUI();
      sortItems();
    });
  }

  let featuredTimer: number | null = null;

  const updateFeatured = (item: HTMLElement) => {
    if (!(item instanceof HTMLElement)) return;
    const data = item.dataset;
    const name = data.itemName || "";
    const description = data.itemDescription || "";
    const price = data.itemPrice || "0";
    const category = data.itemCategory || "";
    const colors = data.itemColors || "";
    const sizes = data.itemSizes || "";
    const image = data.itemImage || "";
    const isNew = data.itemIsNew === "true";
    const hasImage = image.length > 0;

    if (dom.featured.title) dom.featured.title.textContent = name;
    if (dom.featured.description) dom.featured.description.textContent = description;
    if (dom.featured.price) dom.featured.price.textContent = `$${price} CAD`;
    if (dom.featured.previewName) dom.featured.previewName.textContent = name;
    if (dom.featured.previewCategory) dom.featured.previewCategory.textContent = category.toUpperCase();
    if (dom.featured.previewDrop) dom.featured.previewDrop.textContent = isNew ? "New" : "Standard";

    if (dom.featured.previewImage && dom.featured.previewIconContainer) {
      if (hasImage) {
        if (dom.featured.previewImage instanceof HTMLImageElement) {
          dom.featured.previewImage.src = image;
          dom.featured.previewImage.alt = name;
        }
        dom.featured.previewImage.classList.remove("hidden");
        dom.featured.previewIconContainer.classList.add("hidden");
      } else {
        dom.featured.previewImage.classList.add("hidden");
        dom.featured.previewIconContainer.classList.remove("hidden");
      }
    }

    if (dom.featured.colors) dom.featured.colors.textContent = colors;
    if (dom.featured.sizes) dom.featured.sizes.textContent = sizes;
    if (dom.featured.colorsRow) dom.featured.colorsRow.classList.toggle("hidden", !colors);
    if (dom.featured.sizesRow) dom.featured.sizesRow.classList.toggle("hidden", !sizes);
    if (dom.featured.newBadge) dom.featured.newBadge.classList.toggle("hidden", !isNew);

    if (dom.featured.cta) {
      dom.featured.cta.setAttribute("data-item-name", name);
      dom.featured.cta.setAttribute("data-item-price", price);
      const json = data.itemJson || "{}";
      dom.featured.cta.setAttribute("data-item-json", json);
    }

    dom.previewIcons.forEach((icon) => {
      const iconCategory = icon.getAttribute("data-preview-icon");
      icon.classList.toggle("hidden", iconCategory !== category);
    });
  };

  if (dom.featured.cta) {
    dom.featured.cta.addEventListener("click", () => {
      const json = dom.featured.cta!.getAttribute("data-item-json") || "{}";
      try {
        const itemData = JSON.parse(json);
        window.dispatchEvent(new CustomEvent("open-merch-modal", { detail: itemData }));
      } catch (e) {
        console.error("Failed to parse item data", e);
      }
    });
  }

  const getCarouselItems = () => {
    const featured = dom.merchItems.filter((item) => (item as HTMLElement).dataset.itemIsNew === "true");
    return featured.length > 0 ? featured : dom.merchItems.slice(0, 3);
  };

  const startFeaturedCarousel = () => {
    const items = getCarouselItems();
    if (items.length === 0) return;
    let index = 0;
    updateFeatured(items[index] as HTMLElement);
    featuredTimer = window.setInterval(() => {
      index = (index + 1) % items.length;
      updateFeatured(items[index] as HTMLElement);
    }, 4500);
  };

  const stopFeaturedCarousel = () => {
    if (featuredTimer) {
      clearInterval(featuredTimer);
      featuredTimer = null;
    }
  };

  const setFeaturedVisibility = (visible: boolean) => {
    if (dom.featuredSection) dom.featuredSection.classList.toggle("hidden", !visible);
    if (dom.featuredHeader) {
      dom.featuredHeader.classList.toggle("border-b", visible);
      dom.featuredHeader.classList.toggle("border-[var(--border-dim)]", visible);
    }
    if (dom.inventoryDivider) {
      dom.inventoryDivider.classList.toggle("border-t", visible);
      dom.inventoryDivider.classList.toggle("border-[var(--border-dim)]", visible);
      dom.inventoryDivider.classList.toggle("pt-6", visible);
    }
  };

  startFeaturedCarousel();

  dom.categoryButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const category = button.getAttribute("data-category") || "all";
      const label = button.textContent?.trim() || "All";

      dom.categoryButtons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");

      let visibleCount = 0;
      dom.merchItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const itemCategory = item.dataset.itemCategory;
        const isVisible = category === "all" || itemCategory === category;
        item.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (dom.emptyState) {
        dom.emptyState.classList.toggle("hidden", visibleCount > 0);
      }
      if (dom.activeLabel) {
        dom.activeLabel.textContent = label.replace("Items", "").trim();
      }

      if (category !== "all") {
        setFeaturedVisibility(false);
        stopFeaturedCarousel();
      } else {
        setFeaturedVisibility(true);
        if (!featuredTimer) startFeaturedCarousel();
      }
    });
  });
</script>
