---
import ImmersiveLayout from "../layouts/ImmersiveLayout.astro";
import BackgroundText from "../components/effects/BackgroundText.astro";
import CtaButton from "../components/common/CtaButton";
import MerchCard from "../components/merch/MerchCard.astro";
import { merchItems, categories } from "../data/merch";
import { LINKS } from "../config/links";
import PixelBadge from "../components/common/PixelBadge.astro";
import MerchPurchaseModal from "../components/merch/MerchPurchaseModal.tsx";

const featuredItem =
  merchItems.find((item) => item.isNew && !item.isSoldOut) ?? merchItems[0];
---

<ImmersiveLayout title="UBC Game Dev // Loadout Terminal">
  <MerchPurchaseModal client:load />
  <main>
    <!-- Loadout Header -->
    <section class="relative overflow-hidden pt-28 pb-12 md:pt-32 md:pb-16">
      <div class="pointer-events-none absolute inset-0 z-0">
        <div
          class="absolute -top-24 left-1/2 h-[420px] w-[420px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,var(--cyber-blue)_0%,transparent_60%)] opacity-[0.15]">
        </div>
        <div
          class="absolute left-8 top-12 h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_70%)] opacity-[0.12]">
        </div>
        <div
          class="absolute -right-20 top-20 h-[320px] w-[320px] rounded-full bg-[radial-gradient(circle,var(--cyber-magenta)_0%,transparent_70%)] opacity-[0.10]">
        </div>
      </div>

      <div class="container-page relative z-10 mx-auto px-4">
        <div class="relative">
          <BackgroundText
            text="ARMORY"
            className="pointer-events-none top-0 left-1/2 -translate-x-1/2 text-7xl opacity-[0.06] md:text-[11rem]"
          />
          <div class="relative z-10 flex flex-col items-center text-center">
            <PixelBadge
              label="Loadout Menu"
              variant="brand"
            />
            <h1
              class="mt-4 text-4xl font-black uppercase tracking-tight text-white md:text-6xl lg:text-7xl">
              Merch <span class="text-[var(--cyber-yellow)]">Armory</span>
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--text-muted)] md:text-xl">
              Configure your operator look. Every purchase supports club ops, workshops, and showcases.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Loadout Terminal -->
    <section class="container-page mx-auto px-4 pb-24">
      <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
        <!-- Left Menu -->
        <aside class="hud-card h-fit border border-[var(--border-dim)] bg-[var(--bg-panel)]/80 pb-8 text-sm shadow-[0_0_30px_rgba(0,0,0,0.55)] backdrop-blur">
          <div class="border-b border-[var(--border-dim)] bg-[var(--bg-deep)] px-5 py-4">
            <p class="font-tech text-xs uppercase tracking-[0.25em] text-[var(--text-muted)]">
              Outfit Console // v3.2
            </p>
          </div>
          <div class="mt-4 flex flex-col gap-2 px-4">
            <button
              data-category="all"
              class="filter-btn active loadout-btn">
              <span>All Items</span>
              <span class="loadout-btn-indicator">//</span>
            </button>
            {
              categories
                .filter((c) => c.id !== "all")
                .map((cat) => (
                  <button
                    data-category={cat.id}
                    class="filter-btn loadout-btn">
                    <span>{cat.label}</span>
                    <span class="loadout-btn-indicator">//</span>
                  </button>
                ))
            }
          </div>

          <div class="mt-8 px-5">
            <div class="hud-card border border-[var(--border-dim)] bg-[var(--bg-deep)]/70 p-4">
              <p class="font-tech text-xs uppercase tracking-widest text-[var(--cyber-blue)]">Operator Status</p>
              <div class="mt-3 space-y-2 text-[10px] text-[var(--text-muted)]">
                <div class="flex items-center justify-between">
                  <span>Credits</span>
                  <span class="text-white">READY</span>
                </div>
                <div class="flex items-center justify-between">
                  <span>Inventory</span>
                  <span class="text-white">SYNCED</span>
                </div>
                <div class="flex items-center justify-between">
                  <span>Drop Rate</span>
                  <span class="text-[var(--cyber-yellow)]">ACTIVE</span>
                </div>
              </div>
            </div>
          </div>
        </aside>

        <!-- Right Panel -->
        <div class="relative overflow-hidden border border-[var(--border-dim)] bg-[var(--bg-panel)]/70 backdrop-blur">
          <div class="pointer-events-none absolute inset-0 z-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.3)_50%),linear-gradient(90deg,rgba(0,240,255,0.05),rgba(255,0,170,0.03),rgba(0,0,0,0))] bg-[length:100%_2px,3px_100%] opacity-20"></div>

          <div class="relative z-10 space-y-8 p-6 md:p-10">
            <div class="flex items-center justify-between border-b border-[var(--border-dim)] pb-4">
              <div>
                <p class="font-tech text-xs uppercase tracking-widest text-[var(--text-muted)]">Loadout Preview</p>
                <h2 class="text-2xl font-bold uppercase tracking-wide text-white md:text-3xl">
                  Outfit Config
                </h2>
              </div>
              <span class="font-tech text-xs text-[var(--cyber-yellow)]">SYNC // OK</span>
            </div>

            <div class="hud-card border border-[var(--border-dim)] bg-[var(--bg-deep)]/60 p-6">
              <div class="flex items-center justify-between">
                <p class="font-tech text-xs uppercase tracking-widest text-[var(--cyber-magenta)]">Featured Drop</p>
                {featuredItem?.isNew && (
                  <span class="rounded-sm bg-[var(--cyber-yellow)] px-2 py-0.5 text-[10px] font-bold text-black">
                    NEW
                  </span>
                )}
              </div>
              <h3 class="mt-3 text-2xl font-bold text-white md:text-3xl">
                {featuredItem?.name}
              </h3>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                {featuredItem?.description}
              </p>

              <div class="mt-5 space-y-2 text-[10px] uppercase tracking-widest text-[var(--text-muted)]">
                {featuredItem?.colors && (
                  <div class="flex items-center justify-between">
                    <span>Colors</span>
                    <span class="text-white">{featuredItem.colors.join(" / ")}</span>
                  </div>
                )}
                {featuredItem?.sizes && (
                  <div class="flex items-center justify-between">
                    <span>Sizes</span>
                    <span class="text-white">{featuredItem.sizes.join(" / ")}</span>
                  </div>
                )}
              </div>

              <div class="mt-6 flex items-center justify-between">
                <span class="text-3xl font-black text-[var(--cyber-yellow)]">
                  ${featuredItem?.price}
                </span>
                <button
                  class="relative inline-flex items-center gap-2 bg-[var(--cyber-blue)] px-5 py-2 text-xs font-bold uppercase tracking-widest text-black transition-all hover:-translate-y-1 hover:bg-white hover:shadow-[0_0_18px_var(--cyber-blue)]"
                  style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
                  onclick={`window.dispatchEvent(new CustomEvent('open-merch-modal', { detail: { itemName: '${featuredItem?.name}', price: ${featuredItem?.price ?? 0} } }))`}
                >
                  Equip / Purchase
                </button>
              </div>
            </div>

            <div class="border-t border-[var(--border-dim)] pt-6">
              <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                  <p class="font-tech text-xs uppercase tracking-widest text-[var(--text-muted)]">
                    Inventory Feed
                  </p>
                  <h3 class="text-2xl font-bold uppercase text-white">
                    Items // <span id="active-category-label" class="text-[var(--cyber-yellow)]">All</span>
                  </h3>
                </div>
                <div class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-[var(--text-muted)]">
                  <span>Sort</span>
                  <span class="text-white">Newest</span>
                  <span>·</span>
                  <span class="text-white">Price</span>
                </div>
              </div>

              <div class="mt-6 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
                {
                  merchItems.map((item) => (
                    <div
                      data-merch-item
                      data-item-category={item.category}
                      class="h-full">
                      <MerchCard {...item} />
                    </div>
                  ))
                }
              </div>

              <div
                id="empty-state"
                class="hidden py-16 text-center">
                <p class="font-tech text-sm uppercase tracking-widest text-[var(--text-muted)]">
                  No gear in this category
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Drop Notification -->
    <section class="container-page mx-auto px-4 pb-20">
      <div
        class="hud-card border border-[var(--brand)]/30 bg-[linear-gradient(120deg,rgba(255,255,255,0.03),rgba(0,0,0,0.6))] p-8 text-center md:p-12">
        <h2 class="text-2xl font-bold uppercase text-white md:text-3xl">Next Drop Incoming</h2>
        <p class="mx-auto mt-3 max-w-xl text-[var(--text-muted)]">
          Join our Discord to get notified when new gear deploys and for exclusive operator discounts.
        </p>
        <CtaButton
          client:load
          label="Join Discord"
          href={LINKS.discord}
          className="mt-6"
        />
      </div>
    </section>
  </main>
</ImmersiveLayout>

<style>
  .loadout-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    border: 1px solid var(--border-dim);
    padding: 12px 16px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(5, 5, 8, 0.6);
    color: var(--text-muted);
    transition: all 0.2s ease;
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
  }

  .loadout-btn:hover {
    border-color: var(--brand);
    color: white;
    background: rgba(10, 10, 12, 0.8);
  }

  .loadout-btn-indicator {
    color: var(--cyber-yellow);
    opacity: 0.6;
  }

  .filter-btn.active {
    background: var(--cyber-yellow);
    color: #050505;
    border-color: var(--cyber-yellow);
    box-shadow: 0 0 15px rgba(252, 238, 10, 0.3);
  }

  .filter-btn.active .loadout-btn-indicator {
    color: #050505;
    opacity: 1;
  }

</style>

<script>
  const categoryButtons = document.querySelectorAll("[data-category]");
  const merchItems = document.querySelectorAll("[data-merch-item]");
  const emptyState = document.getElementById("empty-state");
  const activeLabel = document.getElementById("active-category-label");

  categoryButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const category = button.getAttribute("data-category");
      const label = button.textContent?.trim() || "All";

      categoryButtons.forEach((btn) => {
        btn.classList.remove("active");
      });
      button.classList.add("active");

      let visibleCount = 0;
      merchItems.forEach((item) => {
        const itemCategory = item.getAttribute("data-item-category");
        if (category === "all" || itemCategory === category) {
          (item as HTMLElement).style.display = "";
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = "none";
        }
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
      if (activeLabel) {
        activeLabel.textContent = label.replace("Items", "").trim();
      }
    });
  });
</script>
