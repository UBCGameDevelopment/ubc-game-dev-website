---
import ImmersiveLayout from "../layouts/ImmersiveLayout.astro";
import { GameService } from "../services";

import CyberMarquee from "../components/effects/CyberMarquee.astro";
import GlitchText from "../components/effects/GlitchText";
import BackgroundText from "../components/effects/BackgroundText.astro";

const { years, gamesByYear } = GameService.getGroupedByYearSorted();
---

<ImmersiveLayout title="Club Timeline // Games">
  <CyberMarquee text="TIMELINE ARCHIVE /// CLASSIFIED" direction="left" className="top-32 left-0 fixed opacity-[0.02]" />
  <div class="container-page mx-auto px-4 pt-32 pb-24 min-h-screen flex flex-col md:flex-row gap-8 lg:gap-16 relative z-10">
    
    <!-- Sidebar Timeline Navigation -->
    <aside class="w-full md:w-64 shrink-0 md:sticky md:top-32 h-fit">
      <div class="hud-card p-6 border border-[var(--border-dim)] bg-[var(--bg-panel)]/80 backdrop-blur-md">
        <h2 class="font-black text-xl mb-6 tracking-widest uppercase text-white border-b border-[var(--border-dim)] pb-4">
          Club Timeline
        </h2>
        
        <nav class="space-y-2">
          {years.map(year => (
            <a 
              href={`#year-${year}`}
              class="block w-full text-left px-4 py-3 rounded text-[var(--text-muted)] hover:text-white hover:bg-[var(--bg-deep)] hover:border-l-2 hover:border-[var(--cyber-yellow)] transition-all font-tech tracking-wider"
            >
              <span class="text-[var(--cyber-yellow)] mr-2">//</span> {year}
            </a>
          ))}
        </nav>
      </div>

      <!-- Decorative Elements -->
      <div class="mt-8 hidden md:block">
        <div class="font-tech text-xs text-[var(--border-dim)]">
          <p>SYS.STATUS: ONLINE</p>
          <p>ARCHIVE_ACCESS: GRANTED</p>
        </div>
      </div>
    </aside>

    <!-- Main Content: Games Stream -->
    <div class="flex-1 space-y-32">
       {years.map(year => (
          <div id={`year-${year}`} class="scroll-mt-32 relative">
             <!-- Year Marker -->
             <div class="flex items-center gap-4 mb-12">
               <BackgroundText text={year} className="text-6xl -top-10 -left-4 md:-left-12 opacity-20" />
               <h3 class="text-3xl font-bold text-[var(--cyber-yellow)] relative z-10 flex items-center gap-2">
                 <GlitchText client:visible text={year} tag="span" /> 
                 <span class="text-[var(--text-muted)] text-lg font-normal"> // Season Archives</span>
               </h3>
               <div class="h-px bg-[var(--border-dim)] flex-1 ml-4"></div>
             </div>

             <div class="space-y-16">
              {gamesByYear[year].map((game) => {
                const imageSrc = GameService.getGameImageSrc(game);
                return (
                  <article class="group relative grid lg:grid-cols-[1.2fr_1fr] gap-8 p-6 lg:p-0">
                      <!-- Left: Content -->
                      <div class="flex flex-col justify-center order-2 lg:order-1">
                        <div class="mb-4">
                           <span class="bg-[var(--cyber-yellow)] text-black text-xs font-bold px-2 py-1 uppercase tracking-wider inline-block mb-2">Project</span>
                           <h4 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-4 glitch-hover" data-text={game.name}>{game.name}</h4>
                           
                           {game.award && (
                             <div class="inline-flex items-center gap-2 border border-[var(--cyber-yellow)] px-3 py-2 mb-6 bg-[var(--cyber-yellow)]/10">
                               <span class="text-[var(--cyber-yellow)]">★</span>
                               <span class="font-bold text-[var(--cyber-yellow)] text-sm uppercase tracking-wide">{game.award}</span>
                             </div>
                           )}

                           <p class="text-[var(--text-muted)] text-lg leading-relaxed mb-8 border-l-2 border-[var(--border-dim)] pl-6">
                             {game.description}
                           </p>

                           <!-- Team Members -->
                           {game.teamMembers && (
                             <div class="space-y-2">
                               <h5 class="text-xs font-bold text-[var(--brand)] uppercase tracking-widest flex items-center gap-2">
                                 <span class="w-1 h-1 bg-[var(--brand)] rounded-full"></span> Team Members
                               </h5>
                               <div class="flex flex-wrap gap-2">
                                 {game.teamMembers.map(member => (
                                   <span class="px-3 py-1 rounded-full border border-[var(--border-dim)] text-xs text-[var(--text-muted)] bg-[var(--bg-panel)] font-tech">
                                     {member}
                                   </span>
                                 ))}
                               </div>
                             </div>
                           )}
                           
                           <div class="mt-8">
                             {game.gameLink && (
                               <a 
                                 href={game.gameLink} 
                                 target="_blank" 
                                 rel="noopener noreferrer"
                                 class="inline-flex items-center gap-2 bg-[var(--cyber-blue)] text-black font-bold uppercase tracking-widest text-sm px-6 py-3 hover:bg-white transition-all transform hover:-translate-y-1 hover:shadow-[0_0_15px_var(--cyber-blue)]"
                                 style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
                               >
                                 <span>Play Game</span>
                                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                               </a>
                             )}
                           </div>
                        </div>
                      </div>

                      <!-- Right: Image -->
                      <div class="order-1 lg:order-2">
                         <div class="hud-card lg:-mr-6 relative aspect-video overflow-hidden rounded-lg group-hover:border-[var(--cyber-blue)] transition-colors border-2 border-transparent">
                            {game.media && game.media.type === 'video' ? (
                              <iframe 
                                src={game.media.videoUrl} 
                                title={game.name}
                                class="absolute inset-0 w-full h-full"
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen
                              ></iframe>
                            ) : (
                              <>
                                <div 
                                  class="absolute inset-0 bg-cover bg-center transform transition-transform duration-700 group-hover:scale-105"
                                  style={`background-image: url('${imageSrc}');`}
                                >
                                  <div class="absolute inset-0 bg-[var(--bg-deep)]/20 group-hover:bg-transparent transition-colors"></div>
                                </div>
                                
                                <!-- CRT Scanline Overlay -->
                                <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] z-10 bg-[length:100%_2px,3px_100%] pointer-events-none"></div>
                              </>
                            )}
                         </div>
                      </div>
                    </article>
                  );
               })}
             </div>
          </div>
       ))}
    </div>
  </div>

  <style>
    .glitch-hover:hover {
      animation: glitch-skew 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite;
      color: var(--cyber-blue);
    }
    @keyframes glitch-skew {
      0% { transform: skew(0deg); }
      20% { transform: skew(-2deg); }
      40% { transform: skew(2deg); }
      60% { transform: skew(0deg); }
      80% { transform: skew(-1deg); }
      100% { transform: skew(0deg); }
    }
  </style>
</ImmersiveLayout>
