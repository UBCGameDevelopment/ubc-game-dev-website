---
import Layout from "../layouts/Layout.astro";
import Timeline from "../components/games/Timeline.astro";
import GameCard from "../components/games/GameCard.astro";
import { games } from "../data/games";
---

<Layout>
    <main class="container-page">
        <!-- Page Header -->
        <section class="my-12 text-center md:my-16">
            <div
                class="bg-brand-500/20 border-brand-500/30 mb-4 inline-flex items-center gap-2 rounded-full border px-4 py-1.5">
                <span class="text-brand-400 text-sm font-semibold">Our Projects</span>
            </div>

            <h1
                class="bg-gradient-to-r from-white via-gray-100 to-gray-300 bg-clip-text text-4xl font-extrabold tracking-tight text-transparent md:text-6xl">
                Game Showcase
            </h1>
            <p class="mx-auto mt-4 max-w-3xl text-lg leading-relaxed text-gray-50/80">
                Explore the amazing games created by our talented teams. Each project represents countless hours of
                creativity, collaboration, and passion for game development.
            </p>
        </section>

        <!-- Timeline + Games -->
        <section class="my-12 md:my-16">
            <div class="items-start gap-8 md:grid md:grid-cols-[minmax(180px,220px)_minmax(0,1fr)] lg:gap-14">
                <aside class="order-2 md:sticky md:top-24 md:order-1">
                    <div
                        class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 shadow-xl ring-1 shadow-black/30 ring-white/10 backdrop-blur-xl">
                        <h2 class="mb-3 text-lg font-bold tracking-wide">Club Timeline</h2>
                        <Timeline />
                    </div>
                </aside>

                <div class="order-1 md:order-2">
                    {
                        games.length > 0 ? (
                            <div class="space-y-8 md:space-y-12">
                                {games.map((game) => (
                                    <GameCard {...game} />
                                ))}
                            </div>
                        ) : (
                            <div class="py-16 text-center">
                                <svg
                                    class="mx-auto mb-4 h-24 w-24 text-white/10"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    />
                                </svg>
                                <p class="mb-2 text-xl text-gray-50/60">No games yet</p>
                                <p class="text-sm text-gray-50/40">Check back soon for our latest projects!</p>
                            </div>
                        )
                    }
                </div>
            </div>
        </section>
    </main></Layout
>
