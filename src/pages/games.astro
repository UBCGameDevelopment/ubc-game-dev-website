---
import Layout from "../layouts/Layout.astro";
import Timeline from "../components/games/Timeline/Timeline.astro";
import GameCard from "../components/games/GameCard/GameCard.astro";
import GameGrid from "../components/games/GameGrid";
import { GameService } from "../services";

const games = GameService.getAll();
import PixelBadge from "../components/common/PixelBadge.astro";
---

<Layout>
  <main class="container-page">
    <!-- Page Header -->
    <section class="relative my-12 overflow-hidden text-center md:my-16">
      <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center">
        <div
          class="h-[400px] w-[400px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_70%)] opacity-[0.08]"
        >
        </div>
      </div>

      <div class="relative z-10">
        <div class="mb-4 inline-flex justify-center">
          <PixelBadge
            label="Our Projects"
            variant="brand"
          />
        </div>

        <h1 class="font-pixel text-4xl font-extrabold tracking-tight text-[var(--text)] md:text-6xl">Game Showcase</h1>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-relaxed text-[var(--text-muted)]">
          Explore the amazing games created by our talented teams. Each project represents countless hours of
          creativity, collaboration, and passion for game development.
        </p>
      </div>
    </section>

    <!-- Timeline + Games -->
    <section class="my-12 md:my-16">
      <div class="items-start gap-8 md:grid md:grid-cols-[minmax(180px,220px)_minmax(0,1fr)] lg:gap-14">
        <aside class="order-2 mb-8 md:sticky md:top-24 md:order-1 md:mb-0">
          <div class="rounded-3xl border border-[var(--border)] bg-[var(--surface-2)] p-5 shadow-xl">
            <h2 class="mb-3 text-lg font-bold tracking-wide text-[var(--text)]">Club Timeline</h2>
            <Timeline />
          </div>
        </aside>

        <div class="order-1 md:order-2">
          <GameGrid client:load />

          <div class="game-cards-container space-y-8 md:space-y-12">
            {
              games.map((game) => (
                <div
                  class="game-card-wrapper"
                  data-game-card
                  data-year={game.year}
                  style="opacity: 0; transform: scale(0.9); filter: blur(8px);"
                >
                  <GameCard {...game} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
