---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/events/EventCard.astro";
import EventTimeline from "../components/events/EventTimeline.astro";

import { events } from "../data/events";
---

<Layout>
    <!-- Header -->
    <div class="mb-8 flex w-full justify-center px-4">
        <div class="mt-20 mb-8 flex w-full max-w-6xl flex-row items-center justify-between md:my-16">
            <p class="text-5xl font-extrabold">Upcoming Events (2025-2026)</p>
            <a
                href="https://discord.gg/RXMxvEcj7B"
                class="rounded-4xl border border-[#E4E4E4] px-4 py-2 whitespace-nowrap text-white transition-colors duration-1000 ease-in-out hover:border-[#BEA9FF] hover:bg-[#BEA9FF] hover:text-black">
                Join our Discord
            </a>
        </div>
    </div>

    <!-- Events with vertical timeline -->
    <div class="flex w-full justify-center px-4 pb-16">
        <div class="w-full max-w-7xl">
            {
                events.map((event, index) => {
                    const isEven = index % 2 === 0;
                    return (
                        <div class="relative mb-8 last:mb-0 md:mb-12">
                            {/* Desktop layout - alternating sides */}
                            <div class="hidden md:grid md:grid-cols-[1fr_80px_1fr] md:gap-8">
                                {/* Left side - shows card on even indices */}
                                <div class={`flex ${isEven ? "justify-end" : "justify-start"}`}>
                                    {isEven && <EventCard {...event} />}
                                </div>

                                {/* Timeline column (center) */}
                                <div class="timeline-container flex h-full justify-center">
                                    <EventTimeline
                                        index={index}
                                        isLast={index === events.length - 1}
                                    />
                                </div>

                                {/* Right side - shows card on odd indices */}
                                <div class={`flex ${isEven ? "justify-start" : "justify-end"}`}>
                                    {!isEven && <EventCard {...event} />}
                                </div>
                            </div>

                            {/* Mobile layout - simple vertical stack */}
                            <div class="md:hidden">
                                <EventCard {...event} />
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>
</Layout>
