---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton";
import LevelCard from "../components/events/LevelCard.astro";
import EventModal from "../components/events/EventModal";
import { EventService } from "../services";
import { LINKS } from "../config/links";

const events = EventService.getAll();

// Prepare events data for the modal
const eventsForModal = events.map((event, index) => ({
  title: event.title,
  date: event.date,
  description: event.description,
  location: event.location,
  mapLink: event.mapLink || "",
  imageSrc: event.image.src,
  isActive: event.isActive,
  chapterNumber: index + 1,
}));

import PixelBadge from "../components/common/PixelBadge.astro";
---

<Layout>
  <main>
    <!-- Header Section -->
    <section class="relative overflow-hidden py-16 md:py-24">
      <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center">
        <div
          class="h-[500px] w-[500px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_70%)] opacity-[0.08]"
        >
        </div>
      </div>

      <div class="container-page relative z-10 mx-auto px-4 text-center">
        <div class="mb-4 inline-flex justify-center">
          <PixelBadge
            label="Season 2025-2026"
            variant="brand"
          />
        </div>

        <h1 class="font-pixel text-4xl font-extrabold tracking-tight text-[var(--text)] md:text-5xl lg:text-6xl">
          Event Chapters
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--text-muted)]">
          Journey through our club events like levels in a game. Complete challenges, unlock achievements, and level up
          your game dev skills!
        </p>

        <!-- Progress Bar -->
        <div class="mx-auto mt-8 max-w-md">
          <div class="mb-2 flex items-center justify-between text-sm">
            <span class="font-medium text-[var(--text)]">Season Progress</span>
            <span class="font-pixel text-[var(--brand)]">
              {events.filter((e) => !e.isActive).length} / {events.length} Completed
            </span>
          </div>
          <div class="h-3 w-full overflow-hidden rounded-full border border-[var(--border)] bg-[var(--surface-2)]">
            <div
              class="h-full rounded-full bg-gradient-to-r from-[var(--brand)] to-[var(--accent)] transition-all duration-500"
              style={`width: ${(events.filter((e) => !e.isActive).length / events.length) * 100}%`}
            >
            </div>
          </div>
        </div>

        <CtaButton
          client:load
          label="Join the Adventure"
          href={LINKS.discord}
          className="mt-8"
        />
      </div>
    </section>

    <!-- Level Grid -->
    <section class="container-page mx-auto px-4 pb-20">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          events.map((event, index) => (
            <LevelCard
              {...event}
              chapterNumber={index + 1}
            />
          ))
        }
      </div>
    </section>

    <!-- Event Modal -->
    <EventModal
      client:load
      events={eventsForModal}
    />
  </main>
</Layout>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const button = target.closest("[data-open-modal]");
    if (button) {
      const index = parseInt(button.getAttribute("data-open-modal") || "0", 10);
      window.dispatchEvent(new CustomEvent("openEventModal", { detail: { index } }));
    }
  });
</script>
