---
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/common/CtaButton";
import LevelCard from "../components/events/LevelCard.astro";
import EventModal from "../components/events/EventModal";
import { EventService } from "../services";
import { LINKS } from "../config/links";

const events = EventService.getAll();
const eventsForModal = EventService.prepareForModal(events);

import PixelBadge from "../components/common/PixelBadge.astro";
import BackgroundText from "../components/effects/BackgroundText.astro";
---

<Layout>
  <main>
    <!-- Header Section -->
    <section class="relative overflow-hidden pt-32 pb-16 md:pb-24">
      <!-- Enhanced Ambient Glow - Space Vibes -->
      <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center">
        <div
          class="h-[600px] w-[600px] rounded-full bg-[radial-gradient(circle,var(--brand)_0%,transparent_50%)] opacity-[0.15]">
        </div>
        <div
          class="absolute -left-32 h-[350px] w-[350px] rounded-full bg-[radial-gradient(circle,var(--accent)_0%,transparent_70%)] opacity-[0.12]">
        </div>
        <div
          class="absolute -right-32 h-[350px] w-[350px] rounded-full bg-[radial-gradient(circle,var(--cyber-magenta)_0%,transparent_70%)] opacity-[0.10]">
        </div>
      </div>

      <!-- Floating Particles -->
      <div class="pointer-events-none absolute inset-0 z-5 overflow-hidden">
        <div
          class="float-anim absolute top-[20%] left-[8%] h-1.5 w-1.5 rotate-45 bg-[var(--brand)] opacity-40"
          style="animation-delay: 0.2s;">
        </div>
        <div
          class="float-anim absolute top-[30%] right-[10%] h-2 w-2 rotate-45 bg-[var(--accent)] opacity-30"
          style="animation-delay: 0.8s;">
        </div>
        <div
          class="float-anim absolute top-[70%] left-[15%] h-1 w-1 rounded-full bg-[var(--cyber-magenta)] opacity-50"
          style="animation-delay: 1.5s;">
        </div>
        <div
          class="float-anim absolute top-[60%] right-[20%] h-1.5 w-1.5 rounded-full bg-[var(--brand)] opacity-35"
          style="animation-delay: 2s;">
        </div>
      </div>

      <div class="container-page relative z-10 mx-auto px-4 text-center">
        <BackgroundText
          text="CHAPTERS"
          className="top-10 left-1/2 -translate-x-1/2 text-8xl opacity-[0.05] md:text-[10rem]"
        />
        <div class="mb-4 inline-flex justify-center">
          <PixelBadge
            label="Season 2025-2026"
            variant="brand"
          />
        </div>

        <h1
          class="font-pixel text-4xl font-extrabold tracking-tight text-[var(--text)] uppercase md:text-5xl lg:text-6xl">
          <span class="text-[var(--cyber-yellow)]">Event</span> Chapters
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--text-muted)]">
          Journey through our club events like levels in a game. Complete challenges, unlock achievements, and level up
          your game dev skills!
        </p>

        <!-- Progress Bar - Cyberpunk Style -->
        <div class="mx-auto mt-10 max-w-md">
          <div class="font-pixel mb-2 flex items-center justify-between text-sm tracking-wider">
            <span class="text-[var(--text)] uppercase">Season Progress</span>
            <span class="text-[var(--cyber-yellow)]">
              {EventService.getCompletedCount()} / {events.length} Completed
            </span>
          </div>
          <div
            class="h-4 w-full bg-[var(--surface-3)] p-0.5"
            style="clip-path: polygon(0 0, 100% 0, 100% 100%, 10px 100%, 0 calc(100% - 10px));">
            <div
              class="relative h-full overflow-hidden bg-[var(--cyber-magenta)] transition-all duration-500"
              style={`width: ${(EventService.getCompletedCount() / events.length) * 100}%`}>
              <div
                class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.2)_50%,transparent_75%)] bg-[length:10px_10px]">
              </div>
            </div>
          </div>
        </div>

        <div class="mt-10">
          <CtaButton
            client:load
            label="Join the Adventure"
            href={LINKS.discord}
            variant="yellow"
          />
        </div>
      </div>
    </section>

    <!-- Level Grid -->
    <section class="container-page mx-auto px-4 pb-20">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          events.map((event, index) => (
            <LevelCard
              {...event}
              chapterNumber={index + 1}
            />
          ))
        }
      </div>
    </section>

    <!-- Event Modal -->
    <EventModal
      client:load
      events={eventsForModal}
    />
  </main>
</Layout>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const button = target.closest("[data-open-modal]");
    if (button) {
      const index = parseInt(button.getAttribute("data-open-modal") || "0", 10);
      window.dispatchEvent(new CustomEvent("openEventModal", { detail: { index } }));
    }
  });
</script>
